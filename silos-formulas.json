(() => {
  "use strict";

  const KEYS = {
    plantMode: "planta_suite_global_plant_mode_v1",
    silosState: "planta_suite_silos_state_v1",
    silosHist: "planta_suite_silos_history_v1",
    colorState: "planta_suite_colorantes_state_v1",
    tankState: "planta_suite_tank_state_v1",
    tankHist: "planta_suite_tank_history_v1"
  };

  const ROUTES = ["inicio", "silos", "colorantes", "tanques"];
  const nf2 = new Intl.NumberFormat("es-CO", { maximumFractionDigits: 2 });
  const nf3 = new Intl.NumberFormat("es-CO", { minimumFractionDigits: 3, maximumFractionDigits: 3 });
  const nf4 = new Intl.NumberFormat("es-CO", { maximumFractionDigits: 4 });
  const nf6 = new Intl.NumberFormat("es-CO", { maximumFractionDigits: 6 });

  const Storage = {
    get(key, fallback) {
      try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : fallback;
      } catch {
        return fallback;
      }
    },
    set(key, value) {
      try {
        localStorage.setItem(key, JSON.stringify(value));
      } catch {
        // ignore storage errors
      }
    },
    remove(key) {
      try {
        localStorage.removeItem(key);
      } catch {
        // ignore storage errors
      }
    }
  };


  const DEFAULT_MAXH_1_36 = 185.5;
  const MAXH_24_26 = 143.5;
  const MAXH_37_38 = 226;
  const MAXH_39 = 124;

  const DATASETS = {
    silosFormulas: {},
    silosTables: {},
    tanks: {}
  };

  async function fetchJSON(path, fallback) {
    try {
      const response = await fetch(path, { cache: "no-store" });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return await response.json();
    } catch {
      return fallback;
    }
  }

  async function loadDatasets() {
    const [silosFormulas, silosTables, tanks] = await Promise.all([
      fetchJSON("./data/silos-formulas.json", {}),
      fetchJSON("./data/silos-tables.json", {}),
      fetchJSON("./data/tanks.json", {})
    ]);
    Object.keys(DATASETS.silosFormulas).forEach((key) => delete DATASETS.silosFormulas[key]);
    Object.assign(DATASETS.silosFormulas, silosFormulas || {});
    Object.keys(DATASETS.silosTables).forEach((key) => delete DATASETS.silosTables[key]);
    Object.assign(DATASETS.silosTables, silosTables || {});
    Object.keys(DATASETS.tanks).forEach((key) => delete DATASETS.tanks[key]);
    Object.assign(DATASETS.tanks, tanks || {});
  }

  function escapeHtml(value) {
    return String(value ?? "").replace(/[&<>"']/g, (char) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;"
    }[char]));
  }

  function askConfirm(message) {
    return window.confirm(message);
  }

  function parseNumber(value) {
    const s = String(value ?? "").trim().replace(/\s+/g, "").replace(",", ".");
    if (!s) return NaN;
    const n = Number(s);
    return Number.isFinite(n) ? n : NaN;
  }

  function nowStamp() {
    return new Date().toLocaleString("es-CO", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit"
    });
  }

  async function copyText(text) {
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return true;
      }
    } catch {
      // ignore and fallback
    }

    try {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      ta.remove();
      return true;
    } catch {
      return false;
    }
  }

  function downloadFile(filename, mime, content) {
    const blob = new Blob([content], { type: mime });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }

  function clampNonNeg(n) {
    return Number.isFinite(n) && n < 0 ? 0 : n;
  }

  function modeText(mode) {
    if (mode === "altura") return "Altura → Litros";
    if (mode === "litros") return "Litros → Altura";
    return "Vacío → Litros";
  }

  function setCurrentYear() {
    const el = document.getElementById("currentYear");
    if (el) el.textContent = new Date().getFullYear();
  }

  function updateHomeSummary() {
    const siloHist = Storage.get(KEYS.silosHist, []);
    const tankHist = Storage.get(KEYS.tankHist, []);
    const colorState = Storage.get(KEYS.colorState, null);

    const homeSilo = document.getElementById("homeSummarySilos");
    const homeSiloSub = document.getElementById("homeSummarySilosSub");
    const homeTank = document.getElementById("homeSummaryTank");
    const homeTankSub = document.getElementById("homeSummaryTankSub");
    const homeColor = document.getElementById("homeSummaryColor");
    const homeColorSub = document.getElementById("homeSummaryColorSub");

    if (siloHist.length) {
      const last = siloHist[0];
      if (last.kind === "move") {
        homeSilo.textContent = last.mov || "Movimiento guardado";
        homeSiloSub.textContent = `Trasladado: ${last.tras || "—"} L • Descargado: ${last.desc || "—"} L`;
      } else {
        homeSilo.textContent = last.silo || "Cálculo guardado";
        homeSiloSub.textContent = `${last.modo || "—"} • ${last.litros || "—"} L • ${last.fecha || "—"}`;
      }
    } else {
      homeSilo.textContent = "Sin registros";
      homeSiloSub.textContent = "Todavía no hay cálculos guardados.";
    }

    if (tankHist.length) {
      const last = tankHist[0];
      homeTank.textContent = last.tanque || "Registro guardado";
      homeTankSub.textContent = `${last.modo || "—"} • ${last.litros || "—"} L • ${last.fecha || "—"}`;
    } else {
      homeTank.textContent = "Sin registros";
      homeTankSub.textContent = "Todavía no hay cálculos guardados.";
    }

    if (colorState) {
      const tipo = colorState.tipo || "brillante";
      const filled = Array.isArray(colorState.colorants)
        ? colorState.colorants.filter((item) => String(item?.name || "").trim() || String(item?.pct || "").trim()).length
        : 0;

      homeColor.textContent = `Tipo: ${tipo}`;
      homeColorSub.textContent = filled
        ? `${filled} colorante(s) diligenciados • Volumen: ${colorState.vol || "—"} ${colorState.volU === "mililitros" ? "mL" : "L"}`
        : "Hay datos guardados, pero todavía no hay colorantes diligenciados.";
    } else {
      homeColor.textContent = "Sin datos";
      homeColorSub.textContent = "Completa un cálculo para ver un resumen aquí.";
    }
  }

  function initRouting() {
    const sections = [...document.querySelectorAll(".route-section")];
    const navButtons = [...document.querySelectorAll("[data-route]")];

    function applyRoute(route, pushHash = true) {
      const safeRoute = ROUTES.includes(route) ? route : "inicio";

      sections.forEach((section) => {
        section.hidden = section.id !== `route-${safeRoute}`;
      });

      navButtons.forEach((button) => {
        const active = button.dataset.route === safeRoute;
        button.classList.toggle("active", active);
        if (active) button.setAttribute("aria-current", "page");
        else button.removeAttribute("aria-current");
      });

      if (pushHash && location.hash !== `#${safeRoute}`) {
        history.replaceState(null, "", `#${safeRoute}`);
      }
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    navButtons.forEach((button) => {
      button.addEventListener("click", () => applyRoute(button.dataset.route));
    });

    window.addEventListener("hashchange", () => {
      applyRoute(location.hash.replace("#", ""), false);
    });

    applyRoute(location.hash.replace("#", "") || "inicio", false);
  }

  function initPlantMode() {
    const toggle = document.getElementById("globalPlantMode");
    const saved = !!Storage.get(KEYS.plantMode, false);

    function apply(value) {
      document.body.classList.toggle("plant-mode", !!value);
      Storage.set(KEYS.plantMode, !!value);
      toggle.checked = !!value;
    }

    apply(saved);
    toggle.addEventListener("change", () => apply(toggle.checked));
  }

  function initInstallPrompt() {
    const installBtn = document.getElementById("installBtn");
    let deferredPrompt = null;

    window.addEventListener("beforeinstallprompt", (event) => {
      event.preventDefault();
      deferredPrompt = event;
      installBtn.hidden = false;
    });

    installBtn.addEventListener("click", async () => {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      try {
        await deferredPrompt.userChoice;
      } catch {
        // ignore
      }
      deferredPrompt = null;
      installBtn.hidden = true;
    });

    window.addEventListener("appinstalled", () => {
      installBtn.hidden = true;
      deferredPrompt = null;
    });
  }

  const SilosModule = (() => {
    const MAX_HIST = 25;

    const FORMULAS = DATASETS.silosFormulas;

    const TABLES = DATASETS.silosTables;

    function getSilosList() {
      const silos = [];
      for (let i = 1; i <= 38; i += 1) {
        if (!FORMULAS[i]) continue;
        silos.push({
          key: `Silo ${i}`,
          kind: "linear",
          siloNo: i,
          a: FORMULAS[i].a,
          b: FORMULAS[i].b,
          maxH: maxHForSilo(i)
        });
      }
      silos.push({ key: "Silo 39", kind: "table_altura", tableKey: "Silo 39 (Medida cm ↔ Litros)", maxH: MAXH_39 });
      silos.push({ key: "Silos 41-42", kind: "table_vacio", tableKey: "Silos 41-42 (Vacío ↔ Litros)" });
      silos.push({ key: "Silos 43-46", kind: "table_vacio", tableKey: "Silos 43-46 (Vacío ↔ Litros)" });
      return silos;
    }

    const cacheTables = new Map();
    let el;

    function maxHForSilo(n) {
      if (n === 24 || n === 26) return MAXH_24_26;
      if (n === 37 || n === 38) return MAXH_37_38;
      if (n === 39) return MAXH_39;
      if (n >= 1 && n <= 36) return DEFAULT_MAXH_1_36;
      return DEFAULT_MAXH_1_36;
    }

    function queryEls() {
      el = {
        silo: document.getElementById("siloSelect"),
        mode: document.getElementById("siloMode"),
        value: document.getElementById("siloValue"),
        valueLabel: document.getElementById("siloValueLabel"),
        range: document.getElementById("siloRange"),
        meta: document.getElementById("siloMeta"),
        modeHelp: document.getElementById("siloModeHelp"),
        saveBtn: document.getElementById("siloSaveBtn"),
        clearBtn: document.getElementById("siloClearBtn"),
        error: document.getElementById("siloError"),
        result: document.getElementById("siloResult"),
        resultTitle: document.getElementById("siloResultTitle"),
        resultSub: document.getElementById("siloResultSub"),
        outAltura: document.getElementById("siloOutAltura"),
        outAlturaSub: document.getElementById("siloOutAlturaSub"),
        outLitros: document.getElementById("siloOutLitros"),
        outLitrosSub: document.getElementById("siloOutLitrosSub"),
        outVacio: document.getElementById("siloOutVacio"),
        outVacioSub: document.getElementById("siloOutVacioSub"),
        outPct: document.getElementById("siloOutPct"),
        outPctSub: document.getElementById("siloOutPctSub"),
        toast: document.getElementById("siloToast"),
        tableData: document.getElementById("siloTableData"),
        history: document.getElementById("siloHistory"),
        histCopyBtn: document.getElementById("siloHistCopyBtn"),
        histCsvBtn: document.getElementById("siloHistCsvBtn"),
        histClearBtn: document.getElementById("siloHistClearBtn"),

        pSilo: document.getElementById("movePrimarySilo"),
        pType: document.getElementById("movePrimaryType"),
        pInitial: document.getElementById("movePrimaryInitial"),
        pFinal: document.getElementById("movePrimaryFinal"),
        pMeta: document.getElementById("movePrimaryMeta"),
        pHelp: document.getElementById("movePrimaryHelp"),

        sSilo: document.getElementById("moveSecondarySilo"),
        sType: document.getElementById("moveSecondaryType"),
        sInitial: document.getElementById("moveSecondaryInitial"),
        sFinal: document.getElementById("moveSecondaryFinal"),
        sMeta: document.getElementById("moveSecondaryMeta"),
        sHelp: document.getElementById("moveSecondaryHelp"),

        delivered: document.getElementById("moveDelivered"),
        moveCalcBtn: document.getElementById("moveCalcBtn"),
        moveClearBtn: document.getElementById("moveClearBtn"),
        moveError: document.getElementById("moveError"),
        moveResult: document.getElementById("moveResult"),
        moveResultSub: document.getElementById("moveResultSub"),
        outTras: document.getElementById("moveOutTras"),
        outDesc: document.getElementById("moveOutDesc"),
        outPrimary: document.getElementById("moveOutPrimary"),
        outPrimarySub: document.getElementById("moveOutPrimarySub"),
        outSecondary: document.getElementById("moveOutSecondary"),
        outSecondarySub: document.getElementById("moveOutSecondarySub"),
        moveToast: document.getElementById("moveToast"),

        mixCurrentName: document.getElementById("mixCurrentName"),
        mixTargetName: document.getElementById("mixTargetName"),
        mixCurrentHelp: document.getElementById("mixCurrentHelp"),
        mixTargetHelp: document.getElementById("mixTargetHelp"),
        mixCurrentLiters: document.getElementById("mixCurrentLiters"),
        mixCapacity: document.getElementById("mixCapacity"),
        mixCalcBtn: document.getElementById("mixCalcBtn"),
        mixClearBtn: document.getElementById("mixClearBtn"),
        mixError: document.getElementById("mixError"),
        mixResult: document.getElementById("mixResult"),
        mixResultTitle: document.getElementById("mixResultTitle"),
        mixResultSub: document.getElementById("mixResultSub"),
        mixOutRemove: document.getElementById("mixOutRemove"),
        mixOutAdd: document.getElementById("mixOutAdd"),
        mixOutAddWho: document.getElementById("mixOutAddWho"),
        mixAddA: document.getElementById("mixAddA"),
        mixAddB: document.getElementById("mixAddB"),
        mixAddC: document.getElementById("mixAddC"),
        mixAddAName: document.getElementById("mixAddAName"),
        mixAddBName: document.getElementById("mixAddBName"),
        mixAddCName: document.getElementById("mixAddCName"),
        mixFinalTotal: document.getElementById("mixFinalTotal"),
        mixFinalComp: document.getElementById("mixFinalComp"),
        mixFinalCompSub: document.getElementById("mixFinalCompSub"),
        mixFinalA: document.getElementById("mixFinalA"),
        mixFinalB: document.getElementById("mixFinalB"),
        mixSteps: document.getElementById("mixSteps"),
        mixSingleAddMetric: document.getElementById("mixSingleAddMetric"),
        mixAddAMetric: document.getElementById("mixAddAMetric"),
        mixAddBMetric: document.getElementById("mixAddBMetric"),
        mixAddCMetric: document.getElementById("mixAddCMetric"),
        mixFinalAMetric: document.getElementById("mixFinalAMetric"),
        mixFinalBMetric: document.getElementById("mixFinalBMetric")
      };
    }

    function getTableAlturaLitros(def) {
      const key = `ALT|${JSON.stringify(def.points)}|${String(def.maxH)}`;
      if (cacheTables.has(key)) return cacheTables.get(key);

      const pts = def.points.map(([h, l]) => ({ h: Number(h), l: Number(l) })).sort((a, b) => a.h - b.h);
      const maxL = pts.reduce((max, p) => Math.max(max, p.l), -Infinity);
      const minL = pts.reduce((min, p) => Math.min(min, p.l), Infinity);
      const table = {
        pts,
        minH: pts[0].h,
        maxH: pts[pts.length - 1].h,
        minL,
        maxL,
        maxHDeclared: def.maxH || pts[pts.length - 1].h
      };
      cacheTables.set(key, table);
      return table;
    }

    function getTableVacioLitros(def) {
      const key = `VAC|${JSON.stringify(def.vacioPoints)}`;
      if (cacheTables.has(key)) return cacheTables.get(key);

      const vpts = def.vacioPoints.map(([v, l]) => ({ v: Number(v), l: Number(l) })).sort((a, b) => a.v - b.v);
      const maxL = vpts.reduce((max, p) => Math.max(max, p.l), -Infinity);
      const minL = vpts.reduce((min, p) => Math.min(min, p.l), Infinity);
      const table = { vpts, minV: vpts[0].v, maxV: vpts[vpts.length - 1].v, minL, maxL };
      cacheTables.set(key, table);
      return table;
    }

    function interp(points, x, xKey, yKey) {
      const n = points.length;
      const minX = points[0][xKey];
      const maxX = points[n - 1][xKey];
      if (x < minX || x > maxX) return null;

      for (let i = 0; i < n - 1; i += 1) {
        const x0 = points[i][xKey];
        const x1 = points[i + 1][xKey];
        if (x >= x0 && x <= x1) {
          const y0 = points[i][yKey];
          const y1 = points[i + 1][yKey];
          const t = (x - x0) / (x1 - x0);
          return y0 + t * (y1 - y0);
        }
      }
      return null;
    }

    function getSelectedSilo() {
      return getSilosList()[Number(el.silo.value)];
    }

    function getSiloCapacityInfo(s) {
      if (s.kind === "linear") {
        const maxL = s.a * s.maxH + s.b;
        return {
          maxH: s.maxH,
          maxL,
          desc: `Ecuación: L = ${nf2.format(s.a)}·h + ${nf2.format(s.b)} • h máx: ${nf2.format(s.maxH)} cm`
        };
      }
      if (s.kind === "table_altura") {
        const t = getTableAlturaLitros(TABLES[s.tableKey]);
        const maxH = TABLES[s.tableKey].maxH || t.maxHDeclared;
        return {
          maxH,
          maxL: t.maxL,
          desc: `Tabla: altura ↔ litros • h máx: ${nf2.format(maxH)} cm`
        };
      }

      const tv = getTableVacioLitros(TABLES[s.tableKey]);
      return {
        maxH: tv.maxV,
        maxL: tv.maxL,
        desc: `Tabla: vacío ↔ litros • vacío máx: ${nf2.format(tv.maxV)} cm`
      };
    }

    function showError(msg) {
      el.error.textContent = msg;
      el.error.hidden = false;
    }

    function clearError() {
      el.error.hidden = true;
      el.error.textContent = "";
    }

    function showMoveError(msg) {
      el.moveError.textContent = msg;
      el.moveError.hidden = false;
    }

    function clearMoveError() {
      el.moveError.hidden = true;
      el.moveError.textContent = "";
    }

    function showMixError(msg) {
      el.mixError.textContent = msg;
      el.mixError.hidden = false;
    }

    function clearMixError() {
      el.mixError.hidden = true;
      el.mixError.textContent = "";
    }

    function setToast(msg) {
      el.toast.textContent = msg || "";
    }

    function setMoveToast(msg) {
      el.moveToast.textContent = msg || "";
    }

    function populateSelects() {
      const options = getSilosList().map((s, idx) => `<option value="${idx}">${s.key}</option>`).join("");
      el.silo.innerHTML = options;
      el.pSilo.innerHTML = options;
      el.sSilo.innerHTML = options;
    }

    function updateMeta() {
      const s = getSelectedSilo();
      const cap = getSiloCapacityInfo(s);
      el.meta.textContent = `${cap.desc} • Capacidad: ${nf2.format(cap.maxL)} L`;
    }

    function updateModeUI() {
      clearError();
      setToast("");
      el.value.classList.remove("invalid");
      const mode = el.mode.value;
      const s = getSelectedSilo();
      const cap = getSiloCapacityInfo(s);

      if (mode === "altura") {
        el.valueLabel.textContent = "Altura (cm)";
        el.value.placeholder = "Ej: 50";
        el.modeHelp.textContent = "Escribe altura y verás litros, vacío y capacidad.";
        el.range.textContent = `Rango: 0–${nf2.format(cap.maxH)} cm (altura).`;
      } else if (mode === "litros") {
        el.valueLabel.textContent = "Litros (L)";
        el.value.placeholder = "Ej: 1000";
        el.modeHelp.textContent = "Escribe litros y verás altura y vacío.";
        el.range.textContent = `Rango: 0–${nf2.format(cap.maxL)} L.`;
      } else {
        el.valueLabel.textContent = "Vacío (cm)";
        el.value.placeholder = "Ej: 100";
        el.modeHelp.textContent = "Escribe vacío y verás litros y altura.";
        el.range.textContent = `Rango: 0–${nf2.format(cap.maxH)} cm (vacío).`;
      }
    }

    function hideResult() {
      el.result.classList.remove("active");
      el.outAltura.textContent = "—";
      el.outLitros.textContent = "—";
      el.outVacio.textContent = "—";
      el.outPct.textContent = "—";
      el.resultSub.textContent = "—";
      el.outAlturaSub.textContent = "—";
      el.outLitrosSub.textContent = "—";
      el.outVacioSub.textContent = "—";
      el.outPctSub.textContent = "—";
      setToast("");
    }

    function loadHistory() {
      const raw = Storage.get(KEYS.silosHist, []);
      return Array.isArray(raw) ? raw : [];
    }

    function saveHistory(hist) {
      Storage.set(KEYS.silosHist, hist.slice(0, MAX_HIST));
    }

    function addHistoryEntry(entry) {
      const hist = loadHistory();
      hist.unshift(entry);
      saveHistory(hist);
      updateHomeSummary();
    }

    function renderHistory() {
      const hist = loadHistory();
      if (!hist.length) {
        el.history.innerHTML = "<div class='alert'><strong>Sin registros</strong></div>";
        return;
      }

      let html = "<div style='display:grid; gap:12px; margin-top:6px'>";
      hist.forEach((r) => {
        if (r.kind === "move") {
          html += `
            <div style="border:1px solid var(--border); border-radius:16px; padding:14px; background:#fff">
              <div style="display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap">
                <div><div style="color:var(--muted); font-size:.82rem">Fecha</div><div style="font-weight:950">${r.fecha}</div></div>
                <div><div style="color:var(--muted); font-size:.82rem">Movimiento</div><div style="font-weight:950">${r.mov}</div></div>
              </div>
              <div style="margin-top:8px; color:var(--muted)"><strong>${r.modo}</strong></div>
              <div style="margin-top:8px; display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap; color:var(--muted)">
                <span>Trasladado: <strong>${r.tras} L</strong></span>
                <span>Descargado: <strong>${r.desc || "—"} L</strong></span>
              </div>
            </div>
          `;
        } else {
          html += `
            <div style="border:1px solid var(--border); border-radius:16px; padding:14px; background:#fff">
              <div style="display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap">
                <div><div style="color:var(--muted); font-size:.82rem">Fecha</div><div style="font-weight:950">${r.fecha}</div></div>
                <div><div style="color:var(--muted); font-size:.82rem">Silo</div><div style="font-weight:950">${r.silo}</div></div>
              </div>
              <div style="margin-top:8px; color:var(--muted)"><strong>${r.modo}</strong> • Entrada: <strong>${r.entrada}</strong></div>
              <div style="margin-top:8px; display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap; color:var(--muted)">
                <span>Altura: <strong>${r.altura} cm</strong></span>
                <span>Litros: <strong>${r.litros} L</strong></span>
                <span>Vacío: <strong>${r.vacio} cm</strong></span>
                <span>%: <strong>${r.pct}</strong></span>
              </div>
            </div>
          `;
        }
      });
      html += "</div>";
      el.history.innerHTML = html;
    }

    async function copyHistory() {
      const hist = loadHistory();
      if (!hist.length) {
        setToast("No hay historial para copiar.");
        return;
      }
      let text = "=== HISTORIAL SILOS ===\n\n";
      hist.forEach((r) => {
        if (r.kind === "move") {
          text += `${r.fecha} | ${r.mov} | ${r.modo} | trasladado: ${r.tras} L | descargado: ${r.desc || "—"} L\n`;
        } else {
          text += `${r.fecha} | ${r.silo} | ${r.modo} | entrada: ${r.entrada} | altura: ${r.altura} cm | litros: ${r.litros} L | vacío: ${r.vacio} cm | %: ${r.pct}\n`;
        }
      });

      const ok = await copyText(text);
      setToast(ok ? "Historial copiado." : "No se pudo copiar el historial.");
    }

    function exportHistoryCSV() {
      const hist = loadHistory();
      if (!hist.length) {
        setToast("No hay historial para exportar.");
        return;
      }

      const lines = ["fecha,tipo,referencia,modo,entrada,altura_cm,litros,vacio_cm,porcentaje,trasladado,descargado"];
      hist.forEach((r) => {
        if (r.kind === "move") {
          lines.push(`"${r.fecha}","mov","${r.mov}","${r.modo}","","","","","","${r.tras}","${r.desc || ""}"`);
        } else {
          lines.push(`"${r.fecha}","calc","${r.silo}","${r.modo}","${r.entrada}","${r.altura}","${r.litros}","${r.vacio}","${r.pct}","",""`);
        }
      });
      downloadFile(`historial_silos_${new Date().toISOString().slice(0, 10)}.csv`, "text/csv;charset=utf-8", lines.join("\n"));
      setToast("CSV descargado.");
    }

    function getTableHtmlLinear(s) {
      const maxL = s.a * s.maxH + s.b;
      let html = `
        <div class="alert">
          <strong>Ecuación</strong><br />
          <span class="muted">L = <span class="mono">${nf2.format(s.a)}·h + ${nf2.format(s.b)}</span> • h máx: ${nf2.format(s.maxH)} cm • Capacidad aprox: ${nf2.format(maxL)} L</span>
        </div>
      `;
      html += `
        <div style="margin-top:12px; overflow:auto; border:1px solid var(--border); border-radius:16px; background:#fff; max-height:420px;">
          <table style="width:100%; border-collapse:collapse; min-width:560px">
            <thead>
              <tr style="background:var(--primary); color:#fff">
                <th style="padding:12px">Altura (cm)</th>
                <th style="padding:12px">Litros (L)</th>
                <th style="padding:12px">Vacío (cm)</th>
              </tr>
            </thead>
            <tbody>
      `;
      for (let h = 0; h <= s.maxH; h += 5) {
        const l = clampNonNeg(s.a * h + s.b);
        const vac = s.maxH - h;
        html += `
          <tr>
            <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(h)}</td>
            <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(l)}</td>
            <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(vac)}</td>
          </tr>
        `;
      }
      html += "</tbody></table></div>";
      return html;
    }

    function renderTable() {
      const s = getSelectedSilo();

      if (s.kind === "linear") {
        el.tableData.innerHTML = getTableHtmlLinear(s);
        return;
      }

      if (s.kind === "table_altura") {
        const t = getTableAlturaLitros(TABLES[s.tableKey]);
        const maxH = TABLES[s.tableKey].maxH || t.maxHDeclared;
        let html = `
          <div class="alert">
            <strong>Tabla</strong><br />
            <span class="muted">Altura (cm) ↔ Litros (L) • h máx: ${nf2.format(maxH)} cm</span>
          </div>
          <div style="margin-top:12px; overflow:auto; border:1px solid var(--border); border-radius:16px; background:#fff; max-height:420px;">
            <table style="width:100%; border-collapse:collapse; min-width:560px">
              <thead>
                <tr style="background:var(--primary); color:#fff">
                  <th style="padding:12px">Altura (cm)</th>
                  <th style="padding:12px">Litros (L)</th>
                  <th style="padding:12px">Vacío (cm)</th>
                </tr>
              </thead>
              <tbody>
        `;
        t.pts.forEach((p) => {
          const vac = maxH - p.h;
          html += `
            <tr>
              <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(p.h)}</td>
              <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(p.l)}</td>
              <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(vac)}</td>
            </tr>
          `;
        });
        html += "</tbody></table></div>";
        el.tableData.innerHTML = html;
        return;
      }

      const tv = getTableVacioLitros(TABLES[s.tableKey]);
      const maxV = tv.maxV;
      let html = `
        <div class="alert">
          <strong>Tabla</strong><br />
          <span class="muted">Vacío (cm) ↔ Litros (L) • Altura = ${nf2.format(maxV)} − vacío</span>
        </div>
        <div style="margin-top:12px; overflow:auto; border:1px solid var(--border); border-radius:16px; background:#fff; max-height:420px;">
          <table style="width:100%; border-collapse:collapse; min-width:620px">
            <thead>
              <tr style="background:var(--primary); color:#fff">
                <th style="padding:12px">Vacío (cm)</th>
                <th style="padding:12px">Altura (cm)</th>
                <th style="padding:12px">Litros (L)</th>
              </tr>
            </thead>
            <tbody>
      `;
      tv.vpts.forEach((p) => {
        const h = maxV - p.v;
        html += `
          <tr>
            <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(p.v)}</td>
            <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(h)}</td>
            <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(p.l)}</td>
          </tr>
        `;
      });
      html += "</tbody></table></div>";
      el.tableData.innerHTML = html;
    }

    function loadState() {
      const saved = Storage.get(KEYS.silosState, null);
      return saved && typeof saved === "object" ? saved : {};
    }

    function saveState() {
      const state = {
        siloIndex: Number(el.silo.value),
        mode: el.mode.value,
        value: el.value.value,
        move: {
          pSilo: el.pSilo.value,
          pType: el.pType.value,
          pInitial: el.pInitial.value,
          pFinal: el.pFinal.value,
          sSilo: el.sSilo.value,
          sType: el.sType.value,
          sInitial: el.sInitial.value,
          sFinal: el.sFinal.value,
          delivered: el.delivered.value
        },
        mix: {
          currentName: el.mixCurrentName.value,
          targetName: el.mixTargetName.value,
          currentLiters: el.mixCurrentLiters.value,
          capacity: el.mixCapacity.value
        }
      };
      Storage.set(KEYS.silosState, state);
      updateHomeSummary();
    }

    function litersFromMeasure(siloObj, tipo, value) {
      if (!Number.isFinite(value)) return null;

      if (siloObj.kind === "linear") {
        const maxH = siloObj.maxH;
        const maxL = siloObj.a * maxH + siloObj.b;

        if (tipo === "litros") {
          if (value < 0 || value > maxL) return null;
          return value;
        }
        if (tipo === "altura") {
          if (value < 0 || value > maxH) return null;
          return clampNonNeg(siloObj.a * value + siloObj.b);
        }
        if (value < 0 || value > maxH) return null;
        const h = maxH - value;
        return clampNonNeg(siloObj.a * h + siloObj.b);
      }

      if (siloObj.kind === "table_altura") {
        const t = getTableAlturaLitros(TABLES[siloObj.tableKey]);
        const maxH = TABLES[siloObj.tableKey].maxH || t.maxHDeclared;
        const maxL = t.maxL;

        if (tipo === "litros") {
          if (value < 0 || value > maxL) return null;
          return value;
        }
        if (tipo === "altura") {
          if (value < 0 || value > maxH) return null;
          const l = interp(t.pts, value, "h", "l");
          return l === null ? null : clampNonNeg(l);
        }
        if (value < 0 || value > maxH) return null;
        const h = maxH - value;
        const l = interp(t.pts, h, "h", "l");
        return l === null ? null : clampNonNeg(l);
      }

      const tv = getTableVacioLitros(TABLES[siloObj.tableKey]);
      const maxV = tv.maxV;
      const maxL = tv.maxL;

      if (tipo === "litros") {
        if (value < 0 || value > maxL) return null;
        return value;
      }
      if (tipo === "vacio") {
        if (value < 0 || value > maxV) return null;
        const l = interp(tv.vpts, value, "v", "l");
        return l === null ? null : clampNonNeg(l);
      }
      if (value < 0 || value > maxV) return null;
      const empty = maxV - value;
      const l = interp(tv.vpts, empty, "v", "l");
      return l === null ? null : clampNonNeg(l);
    }

    function computeAndRender(mode, inputValue, saveToHistory) {
      const s = getSelectedSilo();
      const cap = getSiloCapacityInfo(s);

      if (!Number.isFinite(inputValue)) {
        showError("Ingresa un número válido (coma o punto).");
        el.value.classList.add("invalid");
        hideResult();
        return;
      }

      if (mode === "litros") {
        if (inputValue < 0 || inputValue > cap.maxL) {
          showError(`Fuera de rango. Máximo: ${nf2.format(cap.maxL)} L.`);
          el.value.classList.add("invalid");
          hideResult();
          return;
        }
      } else if (inputValue < 0 || inputValue > cap.maxH) {
        showError(`Fuera de rango. Máximo: ${nf2.format(cap.maxH)} cm.`);
        el.value.classList.add("invalid");
        hideResult();
        return;
      }

      let litros = null;
      let altura = null;
      let vacio = null;
      let note = "";

      if (s.kind === "linear") {
        const maxH = s.maxH;
        const maxL = s.a * maxH + s.b;
        note = `Ecuación L = ${nf2.format(s.a)}·h + ${nf2.format(s.b)}`;

        if (mode === "altura") {
          altura = inputValue;
          litros = clampNonNeg(s.a * altura + s.b);
          vacio = maxH - altura;
        } else if (mode === "litros") {
          litros = inputValue;
          altura = (litros - s.b) / s.a;
          if (altura < 0 || altura > maxH) {
            showError("Litros fuera de rango para esta ecuación.");
            hideResult();
            return;
          }
          vacio = maxH - altura;
        } else {
          vacio = inputValue;
          altura = maxH - vacio;
          litros = clampNonNeg(s.a * altura + s.b);
        }

        const pct = maxL > 0 ? (litros / maxL) * 100 : NaN;
        drawCalcResult(s.key, mode, inputValue, altura, litros, vacio, pct, `Capacidad: ${nf2.format(maxL)} L`, note);

        if (saveToHistory) {
          addHistoryEntry({
            kind: "calc",
            fecha: nowStamp(),
            silo: s.key,
            modo: modeText(mode),
            entrada: `${nf2.format(inputValue)} ${mode === "litros" ? "L" : "cm"}`,
            altura: nf2.format(altura),
            litros: nf2.format(litros),
            vacio: nf2.format(vacio),
            pct: `${nf2.format(pct)}%`
          });
          renderHistory();
          setToast("Guardado.");
        }
        saveState();
        return;
      }

      if (s.kind === "table_altura") {
        const t = getTableAlturaLitros(TABLES[s.tableKey]);
        const maxH = TABLES[s.tableKey].maxH || t.maxHDeclared;
        const maxL = t.maxL;
        note = "Tabla (altura ↔ litros)";

        if (mode === "altura") {
          altura = inputValue;
          litros = interp(t.pts, altura, "h", "l");
          if (litros === null) {
            showError("No se pudo interpolar (fuera de tabla).");
            hideResult();
            return;
          }
          vacio = maxH - altura;
        } else if (mode === "litros") {
          litros = inputValue;
          altura = interp(t.pts, litros, "l", "h");
          if (altura === null) {
            showError("No se pudo interpolar (fuera de tabla).");
            hideResult();
            return;
          }
          vacio = maxH - altura;
        } else {
          vacio = inputValue;
          altura = maxH - vacio;
          litros = interp(t.pts, altura, "h", "l");
          if (litros === null) {
            showError("No se pudo interpolar (fuera de tabla).");
            hideResult();
            return;
          }
        }

        litros = clampNonNeg(litros);
        const pct = maxL > 0 ? (litros / maxL) * 100 : NaN;
        drawCalcResult(s.key, mode, inputValue, altura, litros, vacio, pct, `Capacidad: ${nf2.format(maxL)} L`, note);

        if (saveToHistory) {
          addHistoryEntry({
            kind: "calc",
            fecha: nowStamp(),
            silo: s.key,
            modo: modeText(mode),
            entrada: `${nf2.format(inputValue)} ${mode === "litros" ? "L" : "cm"}`,
            altura: nf2.format(altura),
            litros: nf2.format(litros),
            vacio: nf2.format(vacio),
            pct: `${nf2.format(pct)}%`
          });
          renderHistory();
          setToast("Guardado.");
        }
        saveState();
        return;
      }

      const tv = getTableVacioLitros(TABLES[s.tableKey]);
      const maxV = tv.maxV;
      const maxL = tv.maxL;
      note = "Tabla (vacío ↔ litros)";

      if (mode === "vacio") {
        vacio = inputValue;
        litros = interp(tv.vpts, vacio, "v", "l");
        if (litros === null) {
          showError("No se pudo interpolar (fuera de tabla).");
          hideResult();
          return;
        }
        altura = maxV - vacio;
      } else if (mode === "altura") {
        altura = inputValue;
        vacio = maxV - altura;
        litros = interp(tv.vpts, vacio, "v", "l");
        if (litros === null) {
          showError("No se pudo interpolar (fuera de tabla).");
          hideResult();
          return;
        }
      } else {
        litros = inputValue;
        vacio = interp(tv.vpts, litros, "l", "v");
        if (vacio === null) {
          showError("No se pudo interpolar (fuera de tabla).");
          hideResult();
          return;
        }
        altura = maxV - vacio;
      }

      litros = clampNonNeg(litros);
      const pct = maxL > 0 ? (litros / maxL) * 100 : NaN;
      drawCalcResult(s.key, mode, inputValue, altura, litros, vacio, pct, `Capacidad: ${nf2.format(maxL)} L`, note);

      if (saveToHistory) {
        addHistoryEntry({
          kind: "calc",
          fecha: nowStamp(),
          silo: s.key,
          modo: modeText(mode),
          entrada: `${nf2.format(inputValue)} ${mode === "litros" ? "L" : "cm"}`,
          altura: nf2.format(altura),
          litros: nf2.format(litros),
          vacio: nf2.format(vacio),
          pct: `${nf2.format(pct)}%`
        });
        renderHistory();
        setToast("Guardado.");
      }
      saveState();
    }

    function drawCalcResult(title, mode, inputValue, altura, litros, vacio, pct, pctSub, note) {
      el.result.classList.add("active");
      el.resultTitle.textContent = `Resultado • ${title}`;
      el.resultSub.textContent = `Modo: ${modeText(mode)} • Entrada: ${nf2.format(inputValue)} • ${note}.`;
      el.outAltura.textContent = `${nf2.format(altura)} cm`;
      el.outLitros.textContent = `${nf2.format(litros)} L`;
      el.outVacio.textContent = `${nf2.format(vacio)} cm`;
      el.outPct.textContent = `${nf2.format(pct)}%`;
      el.outAlturaSub.textContent = "Medida / derivada";
      el.outLitrosSub.textContent = "Resultado";
      el.outVacioSub.textContent = "Vacío = máx − altura";
      el.outPctSub.textContent = pctSub;
    }

    function runCalc(saveToHistory) {
      clearError();
      el.value.classList.remove("invalid");
      const v = parseNumber(el.value.value);
      computeAndRender(el.mode.value, v, saveToHistory);
    }

    function clearInputs() {
      el.value.value = "";
      el.value.classList.remove("invalid");
      clearError();
      hideResult();
      saveState();
    }

    function setDefaultTypeFor(siloObj, selectEl) {
      if (siloObj.kind === "table_vacio") selectEl.value = "vacio";
      else selectEl.value = "altura";
    }

    function updateMoveMeta() {
      const p = getSilosList()[Number(el.pSilo.value)];
      const s = getSilosList()[Number(el.sSilo.value)];
      const pCap = getSiloCapacityInfo(p);
      const sCap = getSiloCapacityInfo(s);

      el.pMeta.textContent = `Capacidad: ${nf2.format(pCap.maxL)} L`;
      el.sMeta.textContent = `Capacidad: ${nf2.format(sCap.maxL)} L`;

      el.pHelp.textContent = p.kind === "table_vacio" ? "Recomendado: vacío (cm)." : "Recomendado: altura (cm).";
      el.sHelp.textContent = s.kind === "table_vacio" ? "Recomendado: vacío (cm)." : "Recomendado: altura (cm).";
    }

    function hideMoveResult() {
      el.moveResult.classList.remove("active");
      el.outTras.textContent = "—";
      el.outDesc.textContent = "—";
      el.outPrimary.textContent = "—";
      el.outPrimarySub.textContent = "—";
      el.outSecondary.textContent = "—";
      el.outSecondarySub.textContent = "—";
      el.moveResultSub.textContent = "—";
      setMoveToast("");
    }

    function clearMoveInputs() {
      el.pInitial.value = "";
      el.pFinal.value = "";
      el.sInitial.value = "";
      el.sFinal.value = "";
      el.delivered.value = "";
      clearMoveError();
      hideMoveResult();
      saveState();
    }

    function runMoveCalc() {
      clearMoveError();
      hideMoveResult();

      const pObj = getSilosList()[Number(el.pSilo.value)];
      const sObj = getSilosList()[Number(el.sSilo.value)];
      const pType = el.pType.value;
      const sType = el.sType.value;

      const pInitial = parseNumber(el.pInitial.value);
      const pFinal = parseNumber(el.pFinal.value);
      const sInitial = parseNumber(el.sInitial.value);
      const sFinal = parseNumber(el.sFinal.value);

      const deliveredRaw = String(el.delivered.value ?? "").trim();
      const delivered = deliveredRaw ? parseNumber(deliveredRaw) : 0;

      if (!Number.isFinite(delivered) || delivered < 0) {
        showMoveError("“Se entregó” debe ser un número válido o dejarse vacío, y no puede ser negativo.");
        return;
      }

      const hasPrimary = Number.isFinite(pInitial) && Number.isFinite(pFinal);
      const hasSecondary = Number.isFinite(sInitial) && Number.isFinite(sFinal);

      if (!hasPrimary && !hasSecondary) {
        showMoveError("Ingresa al menos primario inicial/final o secundario inicial/final.");
        return;
      }

      let pIniL = null;
      let pFinL = null;
      let sIniL = null;
      let sFinL = null;

      if (hasPrimary) {
        pIniL = litersFromMeasure(pObj, pType, pInitial);
        pFinL = litersFromMeasure(pObj, pType, pFinal);
        if ([pIniL, pFinL].some((x) => x === null)) {
          showMoveError("Primario: alguna medida está fuera de rango o no se pudo convertir a litros.");
          return;
        }
      }

      if (hasSecondary) {
        sIniL = litersFromMeasure(sObj, sType, sInitial);
        sFinL = litersFromMeasure(sObj, sType, sFinal);
        if ([sIniL, sFinL].some((x) => x === null)) {
          showMoveError("Secundario: alguna medida está fuera de rango o no se pudo convertir a litros.");
          return;
        }
      }

      const moved = hasSecondary ? ((sFinL - sIniL) + delivered) : 0;
      let discharged = null;
      if (hasPrimary) {
        discharged = (pFinL + moved) - pIniL;
        if (discharged < 0) discharged = 0;
      }

      el.moveResult.classList.add("active");
      el.moveResultSub.textContent = "Trasladado = (S fin − S ini) + entregado • Descargado = (P fin + trasladado) − P ini";
      el.outTras.textContent = `${nf2.format(moved)} L`;
      el.outDesc.textContent = discharged === null ? "—" : `${nf2.format(discharged)} L`;

      if (hasPrimary) {
        el.outPrimary.textContent = `${nf2.format(pIniL)} → ${nf2.format(pFinL)}`;
        el.outPrimarySub.textContent = `${pObj.key} (${pType})`;
      } else {
        el.outPrimary.textContent = "—";
        el.outPrimarySub.textContent = "Primario sin datos";
      }

      if (hasSecondary) {
        el.outSecondary.textContent = `${nf2.format(sIniL)} → ${nf2.format(sFinL)}`;
        el.outSecondarySub.textContent = `${sObj.key} (${sType})`;
      } else {
        el.outSecondary.textContent = "—";
        el.outSecondarySub.textContent = "Secundario sin datos";
      }

      if (!hasPrimary && hasSecondary) setMoveToast("Traslado calculado (sin primario).");
      else if (hasPrimary && !hasSecondary) setMoveToast("Descarga calculada (traslado asumido 0).");
      else setMoveToast("Listo.");

      addHistoryEntry({
        kind: "move",
        fecha: nowStamp(),
        mov: `${pObj.key} → ${sObj.key}`,
        modo: "Traslado / descarga",
        tras: nf2.format(moved),
        desc: discharged === null ? "" : nf2.format(discharged)
      });
      renderHistory();
      saveState();
    }

    function parseMix2(text) {
      const raw = String(text ?? "").trim();
      if (!raw) return null;
      const re = /(.+?)\s*\/\s*(.+?)\s+(\d+(?:[.,]\d+)?)\s*\/\s*(\d+(?:[.,]\d+)?)/i;
      const match = raw.match(re);
      if (!match) return null;
      const aName = match[1].trim();
      const bName = match[2].trim();
      const p1 = parseNumber(match[3]);
      const p2 = parseNumber(match[4]);
      if (![p1, p2].every(Number.isFinite)) return null;
      const sum = p1 + p2;
      if (sum <= 0) return null;
      return { kind: 2, names: [aName, bName], p: [p1 / sum, p2 / sum], raw };
    }

    function parseMix3(text) {
      const raw = String(text ?? "").trim();
      if (!raw) return null;
      const re = /(.+?)\s*\/\s*(.+?)\s*\/\s*(.+?)\s+(\d+(?:[.,]\d+)?)\s*\/\s*(\d+(?:[.,]\d+)?)\s*\/\s*(\d+(?:[.,]\d+)?)/i;
      const match = raw.match(re);
      if (!match) return null;
      const names = [match[1].trim(), match[2].trim(), match[3].trim()];
      const p1 = parseNumber(match[4]);
      const p2 = parseNumber(match[5]);
      const p3 = parseNumber(match[6]);
      if (![p1, p2, p3].every(Number.isFinite)) return null;
      const sum = p1 + p2 + p3;
      if (sum <= 0) return null;
      return { kind: 3, names, p: [p1 / sum, p2 / sum, p3 / sum], raw };
    }

    function parseAnyMix(text) {
      return parseMix3(text) || parseMix2(text);
    }

    function describeMix(obj) {
      if (!obj) return "No pude leer el formato. Usa “A/B 60/40” o “A/B/C 50/30/20”.";
      if (obj.kind === 2) {
        return `Detectado (2): A="${obj.names[0]}", B="${obj.names[1]}", %A=${nf2.format(obj.p[0] * 100)}%, %B=${nf2.format(obj.p[1] * 100)}%`;
      }
      return `Detectado (3): A="${obj.names[0]}", B="${obj.names[1]}", C="${obj.names[2]}" • %=${nf2.format(obj.p[0] * 100)}/${nf2.format(obj.p[1] * 100)}/${nf2.format(obj.p[2] * 100)}`;
    }

    function calcOnlyAdd2(totalLiters, pNowA, pWantA, capacity) {
      const eps = 1e-12;
      if (!(totalLiters > 0)) return { error: "Los litros actuales deben ser mayores a 0." };
      if (!(pNowA >= 0 && pNowA <= 1 && pWantA >= 0 && pWantA <= 1)) return { error: "Porcentajes inválidos." };

      if (Math.abs(pWantA - pNowA) < 1e-9) {
        return { addWho: "NONE", addX: 0, removeR: 0, finalT: totalLiters, finalA: totalLiters * pNowA, finalB: totalLiters * (1 - pNowA) };
      }

      const addWho = pWantA > pNowA ? "A" : "B";
      let addX = 0;

      if (addWho === "A") {
        if (pWantA >= 1 - eps) return { error: "Objetivo 100% A no es posible si ya hay B." };
        addX = totalLiters * (pWantA - pNowA) / (1 - pWantA);
      } else {
        if (pWantA <= eps) return { error: "Objetivo 0% A no es posible si ya hay A." };
        addX = totalLiters * (pNowA - pWantA) / pWantA;
      }

      if (!(Number.isFinite(capacity) && capacity > 0)) {
        const finalT = totalLiters + addX;
        const finalA = addWho === "A" ? (totalLiters * pNowA + addX) : (totalLiters * pNowA);
        return { addWho, addX, removeR: 0, finalT, finalA, finalB: finalT - finalA };
      }

      if (totalLiters + addX <= capacity + 1e-9) {
        const finalT = totalLiters + addX;
        const finalA = addWho === "A" ? (totalLiters * pNowA + addX) : (totalLiters * pNowA);
        return { addWho, addX, removeR: 0, finalT, finalA, finalB: finalT - finalA };
      }

      let removeR = 0;
      if (addWho === "A") {
        if (1 - pNowA <= eps) return { error: "Si ya estás en 100% A, no puedes subir más." };
        removeR = totalLiters - capacity * (1 - pWantA) / (1 - pNowA);
      } else {
        if (pNowA <= eps) return { error: "Si ya estás en 0% A, no puedes bajar más." };
        removeR = totalLiters - (pWantA * capacity) / pNowA;
      }

      if (!Number.isFinite(removeR)) return { error: "No se pudo calcular con esa capacidad." };
      if (removeR < 0) removeR = 0;

      const addAfterRemove = (capacity - totalLiters) + removeR;
      if (addAfterRemove < 0) return { error: "Capacidad inválida (menor que lo actual)." };

      const finalT = capacity;
      const aAfterRemove = (totalLiters - removeR) * pNowA;
      const finalA = addWho === "A" ? (aAfterRemove + addAfterRemove) : aAfterRemove;
      return { addWho, addX: addAfterRemove, removeR, finalT, finalA, finalB: finalT - finalA };
    }

    function calcOnlyAdd3(totalLiters, pNow, pWant, capacity) {
      const eps = 1e-12;
      if (!(totalLiters > 0)) return { error: "Los litros actuales deben ser mayores a 0." };

      const sNow = pNow[0] + pNow[1] + pNow[2];
      const sWant = pWant[0] + pWant[1] + pWant[2];
      if (sNow <= eps || sWant <= eps) return { error: "Porcentajes inválidos." };

      const now = pNow.map((x) => x / sNow);
      const want = pWant.map((x) => x / sWant);

      if (!(Number.isFinite(capacity) && capacity > 0)) {
        let factor = 1;
        for (let i = 0; i < 3; i += 1) {
          if (want[i] <= eps) {
            if (now[i] > 1e-9) return { error: "No se puede llegar a 0% de un componente solo adicionando." };
            continue;
          }
          factor = Math.max(factor, now[i] / want[i]);
        }
        const finalT = totalLiters * factor;
        const adds = [0, 0, 0];
        for (let i = 0; i < 3; i += 1) {
          const add = (want[i] * finalT) - (now[i] * totalLiters);
          adds[i] = add < 0 ? 0 : add;
        }
        const finalAmounts = want.map((x) => x * finalT);
        return { removeR: 0, adds, finalT, finalAmounts, pWant: want };
      }

      if (totalLiters > capacity + 1e-9) return { error: "Los litros actuales no pueden ser mayores a la capacidad." };

      const finalT = capacity;
      const target = want.map((x) => x * finalT);

      let removeR = 0;
      for (let i = 0; i < 3; i += 1) {
        if (now[i] <= eps) continue;
        const ri = totalLiters - (target[i] / now[i]);
        if (ri > removeR) removeR = ri;
      }
      if (removeR < 0) removeR = 0;
      if (removeR > totalLiters + 1e-9) return { error: "No es posible con esa capacidad." };

      const remain = now.map((x) => x * (totalLiters - removeR));
      const adds = target.map((t, i) => t - remain[i]);
      if (adds.some((add) => add < -1e-8)) {
        return { error: "No es posible con esa capacidad solo removiendo mezcla y adicionando." };
      }
      for (let i = 0; i < 3; i += 1) {
        if (adds[i] < 0) adds[i] = 0;
      }

      return { removeR, adds, finalT, finalAmounts: target, pWant: want };
    }

    function toggleMixMode(kind) {
      const is2 = kind === 2;
      el.mixSingleAddMetric.style.display = is2 ? "" : "none";
      el.mixAddAMetric.style.display = is2 ? "none" : "";
      el.mixAddBMetric.style.display = is2 ? "none" : "";
      el.mixAddCMetric.style.display = is2 ? "none" : "";
      el.mixFinalAMetric.style.display = is2 ? "none" : "";
      el.mixFinalBMetric.style.display = is2 ? "none" : "";
    }

    function clearMix() {
      clearMixError();
      [el.mixCurrentName, el.mixTargetName, el.mixCurrentLiters, el.mixCapacity].forEach((input) => {
        input.value = "";
        input.classList.remove("invalid");
      });
      el.mixCurrentHelp.textContent = "—";
      el.mixTargetHelp.textContent = "—";
      el.mixResult.classList.remove("active");
      el.mixSteps.innerHTML = "";
      toggleMixMode(2);
      saveState();
    }

    function renderMix() {
      clearMixError();
      [el.mixCurrentName, el.mixTargetName, el.mixCurrentLiters, el.mixCapacity].forEach((input) => input.classList.remove("invalid"));
      el.mixResult.classList.remove("active");

      const now = parseAnyMix(el.mixCurrentName.value);
      const target = parseAnyMix(el.mixTargetName.value);

      el.mixCurrentHelp.textContent = el.mixCurrentName.value.trim() ? describeMix(now) : "—";
      el.mixTargetHelp.textContent = el.mixTargetName.value.trim() ? describeMix(target) : "—";

      if (!now || !target) {
        if (el.mixCurrentName.value.trim() || el.mixTargetName.value.trim()) {
          showMixError("Revisa las mezclas. Usa “A/B 60/40” o “A/B/C 50/30/20”.");
        }
        saveState();
        return;
      }

      if (now.kind !== target.kind) {
        showMixError("Actual y objetivo deben tener el mismo tipo de mezcla.");
        el.mixCurrentName.classList.add("invalid");
        el.mixTargetName.classList.add("invalid");
        saveState();
        return;
      }

      const sameNames = now.names.length === target.names.length && now.names.every((name, index) => name.toLowerCase() === target.names[index].toLowerCase());
      if (!sameNames) {
        showMixError("Los nombres no coinciden entre mezcla actual y objetivo.");
        el.mixCurrentName.classList.add("invalid");
        el.mixTargetName.classList.add("invalid");
        saveState();
        return;
      }

      const totalLiters = parseNumber(el.mixCurrentLiters.value);
      const capacity = parseNumber(el.mixCapacity.value);

      if (!Number.isFinite(totalLiters) || totalLiters <= 0) {
        el.mixCurrentLiters.classList.add("invalid");
        showMixError("Los litros actuales deben ser un número mayor a 0.");
        saveState();
        return;
      }
      if (el.mixCapacity.value.trim() && (!Number.isFinite(capacity) || capacity <= 0)) {
        el.mixCapacity.classList.add("invalid");
        showMixError("La capacidad debe ser un número mayor a 0 o quedar vacía.");
        saveState();
        return;
      }

      toggleMixMode(now.kind);

      if (now.kind === 2) {
        const pNowA = now.p[0];
        const pWantA = target.p[0];
        const result = calcOnlyAdd2(totalLiters, pNowA, pWantA, el.mixCapacity.value.trim() ? capacity : NaN);
        if (result.error) {
          showMixError(result.error);
          saveState();
          return;
        }

        const addName = result.addWho === "A" ? now.names[0] : (result.addWho === "B" ? now.names[1] : "—");
        const pFinalA = result.finalT > 0 ? (result.finalA / result.finalT) : 0;

        el.mixResult.classList.add("active");
        el.mixResultTitle.textContent = "Resultado (2 componentes)";
        el.mixResultSub.textContent = el.mixCapacity.value.trim() ? `Con capacidad ${nf2.format(capacity)} L` : "Sin límite de capacidad";

        el.mixOutRemove.textContent = `${nf2.format(result.removeR)} L`;
        el.mixOutAdd.textContent = `${nf2.format(result.addX)} L`;
        el.mixOutAddWho.textContent = result.addWho === "NONE" ? "No necesitas agregar" : `Agregar: ${addName}`;

        el.mixFinalTotal.textContent = `${nf2.format(result.finalT)} L`;
        el.mixFinalComp.textContent = `${nf2.format(pFinalA * 100)}% / ${nf2.format((1 - pFinalA) * 100)}%`;
        el.mixFinalCompSub.textContent = `${now.names[0]} / ${now.names[1]}`;

        const steps = [];
        if (Math.abs(pWantA - pNowA) < 1e-9) {
          steps.push(`Ya estás en ${nf2.format(pWantA * 100)}% / ${nf2.format((1 - pWantA) * 100)}%.`);
        } else {
          const wantUp = pWantA > pNowA;
          steps.push(`Actual: ${nf2.format(pNowA * 100)}% ${escapeHtml(now.names[0])} y ${nf2.format((1 - pNowA) * 100)}% ${escapeHtml(now.names[1])}.`);
          steps.push(`Objetivo: ${nf2.format(pWantA * 100)}% ${escapeHtml(now.names[0])} y ${nf2.format((1 - pWantA) * 100)}% ${escapeHtml(now.names[1])}.`);
          steps.push(`Para ${wantUp ? "subir" : "bajar"} el % de ${escapeHtml(now.names[0])}, agrega: <strong>${escapeHtml(addName)}</strong>.`);
          if (result.removeR > 1e-6) {
            steps.push(`1) Saca <strong>${nf2.format(result.removeR)} L</strong> de mezcla.`);
            steps.push(`2) Agrega <strong>${nf2.format(result.addX)} L</strong> de <strong>${escapeHtml(addName)}</strong>.`);
          } else {
            steps.push(`Agrega <strong>${nf2.format(result.addX)} L</strong> de <strong>${escapeHtml(addName)}</strong>.`);
          }
        }

        el.mixSteps.innerHTML = `
          <strong>Pasos</strong><br />
          <span class="muted">${steps.join("<br />")}</span>
          <div style="margin-top:10px; padding-top:10px; border-top:1px solid var(--border); color:var(--muted)">
            <strong>Detalle final:</strong><br />
            ${escapeHtml(now.names[0])}: <strong>${nf2.format(result.finalA)} L</strong><br />
            ${escapeHtml(now.names[1])}: <strong>${nf2.format(result.finalB)} L</strong>
          </div>
        `;
        saveState();
        return;
      }

      const result3 = calcOnlyAdd3(totalLiters, now.p, target.p, el.mixCapacity.value.trim() ? capacity : NaN);
      if (result3.error) {
        showMixError(result3.error);
        saveState();
        return;
      }

      el.mixResult.classList.add("active");
      el.mixResultTitle.textContent = "Resultado (3 componentes)";
      el.mixResultSub.textContent = el.mixCapacity.value.trim() ? `Con capacidad ${nf2.format(capacity)} L` : "Sin límite de capacidad";

      el.mixOutRemove.textContent = `${nf2.format(result3.removeR)} L`;
      el.mixAddA.textContent = `${nf2.format(result3.adds[0])} L`;
      el.mixAddB.textContent = `${nf2.format(result3.adds[1])} L`;
      el.mixAddC.textContent = `${nf2.format(result3.adds[2])} L`;
      el.mixAddAName.textContent = now.names[0];
      el.mixAddBName.textContent = now.names[1];
      el.mixAddCName.textContent = now.names[2];

      el.mixFinalTotal.textContent = `${nf2.format(result3.finalT)} L`;
      el.mixFinalComp.textContent = `${nf2.format(result3.pWant[0] * 100)} / ${nf2.format(result3.pWant[1] * 100)} / ${nf2.format(result3.pWant[2] * 100)} %`;
      el.mixFinalCompSub.textContent = `${now.names[0]} / ${now.names[1]} / ${now.names[2]}`;
      el.mixFinalA.textContent = `${nf2.format(result3.finalAmounts[0])} L`;
      el.mixFinalB.textContent = `${nf2.format(result3.finalAmounts[1])} L`;

      const steps3 = [];
      if (result3.removeR > 1e-6) steps3.push(`1) Saca <strong>${nf2.format(result3.removeR)} L</strong> de mezcla.`);
      else steps3.push("1) No necesitas sacar mezcla.");

      const addsTxt = [];
      if (result3.adds[0] > 1e-6) addsTxt.push(`<strong>${nf2.format(result3.adds[0])} L</strong> de ${escapeHtml(now.names[0])}`);
      if (result3.adds[1] > 1e-6) addsTxt.push(`<strong>${nf2.format(result3.adds[1])} L</strong> de ${escapeHtml(now.names[1])}`);
      if (result3.adds[2] > 1e-6) addsTxt.push(`<strong>${nf2.format(result3.adds[2])} L</strong> de ${escapeHtml(now.names[2])}`);
      steps3.push(`2) Agrega: ${addsTxt.length ? addsTxt.join(" + ") : "<strong>0 L</strong> (ya estabas en el objetivo)"}.`);
      steps3.push(`Terminas con <strong>${nf2.format(result3.finalT)} L</strong>.`);

      el.mixSteps.innerHTML = `
        <strong>Pasos</strong><br />
        <span class="muted">${steps3.join("<br />")}</span>
        <div style="margin-top:10px; padding-top:10px; border-top:1px solid var(--border); color:var(--muted)">
          <strong>Detalle final:</strong><br />
          ${escapeHtml(now.names[0])}: <strong>${nf2.format(result3.finalAmounts[0])} L</strong><br />
          ${escapeHtml(now.names[1])}: <strong>${nf2.format(result3.finalAmounts[1])} L</strong><br />
          ${escapeHtml(now.names[2])}: <strong>${nf2.format(result3.finalAmounts[2])} L</strong>
        </div>
      `;
      saveState();
    }

    function bindEvents() {
      el.silo.addEventListener("change", () => {
        updateMeta();
        updateModeUI();
        renderTable();
        hideResult();
        saveState();
        if (String(el.value.value).trim()) runCalc(false);
      });

      el.mode.addEventListener("change", () => {
        updateModeUI();
        hideResult();
        saveState();
        if (String(el.value.value).trim()) runCalc(false);
      });

      el.value.addEventListener("input", () => {
        saveState();
        if (String(el.value.value).trim()) runCalc(false);
        else hideResult();
      });

      el.value.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          runCalc(true);
        }
      });

      el.saveBtn.addEventListener("click", () => runCalc(true));
      el.clearBtn.addEventListener("click", clearInputs);
      el.histCopyBtn.addEventListener("click", copyHistory);
      el.histCsvBtn.addEventListener("click", exportHistoryCSV);
      el.histClearBtn.addEventListener("click", () => {
        if (!askConfirm("¿Seguro que quieres borrar el historial de silos en este dispositivo?")) return;
        Storage.remove(KEYS.silosHist);
        renderHistory();
        updateHomeSummary();
        setToast("Historial eliminado.");
      });

      function onMoveChange() {
        updateMoveMeta();
        saveState();
      }

      el.pSilo.addEventListener("change", () => {
        setDefaultTypeFor(getSilosList()[Number(el.pSilo.value)], el.pType);
        onMoveChange();
      });
      el.sSilo.addEventListener("change", () => {
        setDefaultTypeFor(getSilosList()[Number(el.sSilo.value)], el.sType);
        onMoveChange();
      });
      el.pType.addEventListener("change", onMoveChange);
      el.sType.addEventListener("change", onMoveChange);

      [el.pInitial, el.pFinal, el.sInitial, el.sFinal, el.delivered].forEach((input) => {
        input.addEventListener("input", saveState);
        input.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            event.preventDefault();
            runMoveCalc();
          }
        });
      });

      el.moveCalcBtn.addEventListener("click", runMoveCalc);
      el.moveClearBtn.addEventListener("click", clearMoveInputs);

      [el.mixCurrentName, el.mixTargetName, el.mixCurrentLiters, el.mixCapacity].forEach((input) => {
        input.addEventListener("input", () => {
          if (input.value.trim()) renderMix();
          else {
            saveState();
            if (!el.mixCurrentName.value.trim() && !el.mixTargetName.value.trim() && !el.mixCurrentLiters.value.trim() && !el.mixCapacity.value.trim()) {
              clearMix();
            } else {
              renderMix();
            }
          }
        });
        input.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            event.preventDefault();
            renderMix();
          }
        });
      });

      el.mixCalcBtn.addEventListener("click", renderMix);
      el.mixClearBtn.addEventListener("click", clearMix);
    }

    function restoreState() {
      const state = loadState();
      if (typeof state.siloIndex === "number" && getSilosList()[state.siloIndex]) el.silo.value = String(state.siloIndex);
      if (state.mode) el.mode.value = state.mode;
      if (typeof state.value === "string") el.value.value = state.value;

      if (state.move?.pSilo) el.pSilo.value = state.move.pSilo;
      if (state.move?.pType) el.pType.value = state.move.pType;
      if (typeof state.move?.pInitial === "string") el.pInitial.value = state.move.pInitial;
      if (typeof state.move?.pFinal === "string") el.pFinal.value = state.move.pFinal;
      if (state.move?.sSilo) el.sSilo.value = state.move.sSilo;
      if (state.move?.sType) el.sType.value = state.move.sType;
      if (typeof state.move?.sInitial === "string") el.sInitial.value = state.move.sInitial;
      if (typeof state.move?.sFinal === "string") el.sFinal.value = state.move.sFinal;
      if (typeof state.move?.delivered === "string") el.delivered.value = state.move.delivered;

      if (typeof state.mix?.currentName === "string") el.mixCurrentName.value = state.mix.currentName;
      if (typeof state.mix?.targetName === "string") el.mixTargetName.value = state.mix.targetName;
      if (typeof state.mix?.currentLiters === "string") el.mixCurrentLiters.value = state.mix.currentLiters;
      if (typeof state.mix?.capacity === "string") el.mixCapacity.value = state.mix.capacity;

      if (!state.move?.pType) setDefaultTypeFor(getSilosList()[Number(el.pSilo.value)], el.pType);
      if (!state.move?.sType) setDefaultTypeFor(getSilosList()[Number(el.sSilo.value)], el.sType);
    }

    function init() {
      queryEls();
      populateSelects();
      restoreState();
      updateMeta();
      updateModeUI();
      renderTable();
      renderHistory();
      updateMoveMeta();
      bindEvents();

      if (window.matchMedia("(max-width: 820px)").matches) {
        document.getElementById("siloDetailsTable").open = false;
        document.getElementById("siloDetailsHistory").open = false;
      }

      if (String(el.value.value).trim()) runCalc(false);
      if (el.mixCurrentName.value.trim() || el.mixTargetName.value.trim() || el.mixCurrentLiters.value.trim() || el.mixCapacity.value.trim()) {
        renderMix();
      }
    }

    return { init };
  })();

  const ColorModule = (() => {
    const MAX_COLORANTS = 6;
    const esmaltes = {
      brillante: { label: "Brillante", c1: 44.271, c2: -8.7573 },
      satinado: { label: "Satinado", c1: 44.764, c2: -11.58 },
      monocapa: { label: "Monocapa", c1: 46.75, c2: -15.389 }
    };

    let el;
    let state;
    let lastComputed = null;
    let toastTimer = null;

    function defaultColorants() {
      return [{ name: "", pct: "" }, { name: "", pct: "" }, { name: "", pct: "" }];
    }

    function queryEls() {
      el = {
        tipo: document.getElementById("colorTipo"),
        volumen: document.getElementById("colorVolumen"),
        volumenUnidad: document.getElementById("colorVolumenUnidad"),
        densidad: document.getElementById("colorDensidad"),
        densidadUnidad: document.getElementById("colorDensidadUnidad"),
        detailsSolidos: document.getElementById("colorDetailsSolidos"),
        outVolumenL: document.getElementById("colorOutVolumenL"),
        outVolumenRaw: document.getElementById("colorOutVolumenRaw"),
        outDensidadKgL: document.getElementById("colorOutDensidadKgL"),
        outDensidadRaw: document.getElementById("colorOutDensidadRaw"),
        outSolidosPct: document.getElementById("colorOutSolidosPct"),
        outSolidosFrac: document.getElementById("colorOutSolidosFrac"),
        outMasaTotal: document.getElementById("colorOutMasaTotal"),
        outMasaSolidos: document.getElementById("colorOutMasaSolidos"),
        outConstantes: document.getElementById("colorOutConstantes"),
        error: document.getElementById("colorError"),
        warning: document.getElementById("colorWarning"),
        body: document.getElementById("colorBody"),
        pctTotal: document.getElementById("colorPctTotal"),
        totalAdd: document.getElementById("colorTotalAdd"),
        estado: document.getElementById("colorEstado"),
        addBtn: document.getElementById("colorAddBtn"),
        clearBtn: document.getElementById("colorClearBtn"),
        copyBtn: document.getElementById("colorCopyBtn"),
        txtBtn: document.getElementById("colorTxtBtn"),
        csvBtn: document.getElementById("colorCsvBtn"),
        printBtn: document.getElementById("colorPrintBtn"),
        toast: document.getElementById("colorToast")
      };
    }

    function loadState() {
      const raw = Storage.get(KEYS.colorState, null);
      if (!raw) {
        return { tipo: "brillante", vol: "", volU: "litros", dens: "", densU: "kgL", colorants: defaultColorants() };
      }
      const colorants = Array.isArray(raw.colorants) ? raw.colorants.slice(0, MAX_COLORANTS) : defaultColorants();
      return {
        tipo: raw.tipo || "brillante",
        vol: raw.vol ?? "",
        volU: raw.volU || "litros",
        dens: raw.dens ?? "",
        densU: raw.densU || "kgL",
        colorants: colorants.length ? colorants : defaultColorants()
      };
    }

    function saveState() {
      Storage.set(KEYS.colorState, state);
      updateHomeSummary();
    }

    function clearAlerts() {
      el.error.hidden = true;
      el.warning.hidden = true;
      el.error.textContent = "";
      el.warning.textContent = "";
    }

    function setError(msg) {
      el.error.textContent = msg;
      el.error.hidden = false;
    }

    function setWarning(msg) {
      el.warning.textContent = msg;
      el.warning.hidden = false;
    }

    function showToast(msg, duration = 3000) {
      if (toastTimer) window.clearTimeout(toastTimer);
      el.toast.textContent = msg || "";
      if (msg && duration > 0) {
        toastTimer = window.setTimeout(() => {
          el.toast.textContent = "";
          toastTimer = null;
        }, duration);
      }
    }

    function formatKg(kg) {
      return Number.isFinite(kg) ? `${nf2.format(kg)} kg` : "—";
    }

    function formatL(l) {
      return Number.isFinite(l) ? `${nf4.format(l)} L` : "—";
    }

    function formatPct(value) {
      return Number.isFinite(value) ? `${nf2.format(value)} %` : "—";
    }

    function formatSolids(solidsFrac) {
      if (!Number.isFinite(solidsFrac)) return { pct: "—", frac: "—" };
      return {
        pct: `${nf2.format(solidsFrac * 100)} %`,
        frac: `fracción: ${nf6.format(solidsFrac)}`
      };
    }

    function formatVolRaw(volRaw, volU) {
      if (!Number.isFinite(volRaw)) return "—";
      return volU === "mililitros" ? nf3.format(volRaw) : nf4.format(volRaw);
    }

    function massToPretty(g) {
      if (!Number.isFinite(g)) return { main: "—", sub: "" };
      const abs = Math.abs(g);
      const main = `${nf3.format(g)} g`;
      if (abs >= 1000) return { main, sub: `${nf3.format(g / 1000)} kg` };
      return { main, sub: "" };
    }

    function updateDensityPlaceholder() {
      el.densidad.placeholder = el.densidadUnidad.value === "kgm3" ? "Ej: 1810" : "Ej: 1.81";
    }

    function renderInputs() {
      el.tipo.value = state.tipo;
      el.volumen.value = state.vol;
      el.volumenUnidad.value = state.volU;
      el.densidad.value = state.dens;
      el.densidadUnidad.value = state.densU;
      updateDensityPlaceholder();
    }

    function renderColorants() {
      el.body.innerHTML = "";

      state.colorants.forEach((colorant, idx) => {
        const tr = document.createElement("tr");

        const tdNum = document.createElement("td");
        tdNum.className = "col-num";
        tdNum.textContent = String(idx + 1);
        tr.appendChild(tdNum);

        const tdName = document.createElement("td");
        const inputName = document.createElement("input");
        inputName.type = "text";
        inputName.placeholder = "Ej: Azul 3304";
        inputName.value = colorant.name || "";
        inputName.setAttribute("aria-label", `Nombre del colorante ${idx + 1}`);
        inputName.addEventListener("input", () => {
          state.colorants[idx].name = inputName.value;
          saveState();
          compute();
        });
        tdName.appendChild(inputName);
        tr.appendChild(tdName);

        const tdPct = document.createElement("td");
        const inputPct = document.createElement("input");
        inputPct.type = "text";
        inputPct.inputMode = "decimal";
        inputPct.placeholder = "Ej: 10";
        inputPct.value = colorant.pct || "";
        inputPct.setAttribute("aria-label", `Porcentaje del colorante ${idx + 1}`);
        inputPct.addEventListener("input", () => {
          state.colorants[idx].pct = inputPct.value;
          saveState();
          compute();
        });
        tdPct.appendChild(inputPct);
        tr.appendChild(tdPct);

        const tdResult = document.createElement("td");
        const resMain = document.createElement("span");
        resMain.className = "result-main";
        resMain.id = `colorResultMain-${idx}`;
        resMain.textContent = "—";

        const resSub = document.createElement("span");
        resSub.className = "result-sub";
        resSub.id = `colorResultSub-${idx}`;
        tdResult.appendChild(resMain);
        tdResult.appendChild(resSub);
        tr.appendChild(tdResult);

        const tdRemove = document.createElement("td");
        tdRemove.className = "row-actions";
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "icon-btn";
        btn.textContent = "✕";
        btn.title = "Quitar colorante";
        btn.disabled = state.colorants.length <= 1;
        btn.addEventListener("click", () => {
          state.colorants.splice(idx, 1);
          if (!state.colorants.length) state.colorants = defaultColorants();
          saveState();
          renderColorants();
          compute();
        });
        tdRemove.appendChild(btn);
        tr.appendChild(tdRemove);

        el.body.appendChild(tr);
      });
    }

    function getNormalizedInputs() {
      const tipo = el.tipo.value;
      const volRaw = parseNumber(el.volumen.value);
      let volL = volRaw;
      const volU = el.volumenUnidad.value;
      if (Number.isFinite(volL) && volU === "mililitros") volL = volL / 1000;

      const densRaw = parseNumber(el.densidad.value);
      let densKgL = densRaw;
      const densU = el.densidadUnidad.value;
      if (Number.isFinite(densKgL) && densU === "kgm3") densKgL = densKgL / 1000;

      return { tipo, volRaw, volU, volL, densRaw, densU, densKgL };
    }

    function computeSolidsFrac(tipo, densKgL) {
      const { c1, c2 } = esmaltes[tipo];
      if (!Number.isFinite(densKgL)) return NaN;
      return ((densKgL * c1) + c2) / 100;
    }

    function compute() {
      clearAlerts();
      showToast("", 0);
      [el.volumen, el.densidad].forEach((input) => input.classList.remove("invalid"));

      const { tipo, volRaw, volU, volL, densRaw, densU, densKgL } = getNormalizedInputs();
      const { c1, c2, label } = esmaltes[tipo];
      el.outConstantes.textContent = `${label}: c1 = ${c1}, c2 = ${c2}`;

      let hasError = false;
      if (!Number.isFinite(volRaw) || volRaw <= 0) {
        hasError = true;
        el.volumen.classList.add("invalid");
      }
      if (!Number.isFinite(densRaw) || densRaw <= 0) {
        hasError = true;
        el.densidad.classList.add("invalid");
      }
      if (Number.isFinite(densKgL) && densKgL > 3) {
        setWarning("Densidad inusualmente alta para esmalte. Verifica el valor.");
      }

      el.outVolumenL.textContent = formatL(Number.isFinite(volL) ? volL : NaN);
      el.outVolumenRaw.textContent = `entrada: ${formatVolRaw(volRaw, volU)} ${volU === "litros" ? "L" : "mL"}`;
      el.outDensidadKgL.textContent = Number.isFinite(densKgL) ? `${nf4.format(densKgL)} kg/L` : "—";
      el.outDensidadRaw.textContent = `entrada: ${Number.isFinite(densRaw) ? nf4.format(densRaw) : "—"} ${densU === "kgL" ? "kg/L" : "kg/m³"}`;

      const solFrac = computeSolidsFrac(tipo, densKgL);
      const solidsFmt = formatSolids(solFrac);
      el.outSolidosPct.textContent = solidsFmt.pct;
      el.outSolidosFrac.textContent = solidsFmt.frac;

      const canCompute = !hasError && Number.isFinite(volL) && volL > 0 && Number.isFinite(densKgL) && densKgL > 0 && Number.isFinite(solFrac) && solFrac > 0 && solFrac <= 1;

      if (!canCompute) {
        el.outMasaTotal.textContent = "—";
        el.outMasaSolidos.textContent = "—";

        state.colorants.forEach((_, idx) => {
          const main = document.getElementById(`colorResultMain-${idx}`);
          const sub = document.getElementById(`colorResultSub-${idx}`);
          if (main) main.textContent = "—";
          if (sub) sub.textContent = "";
        });

        el.pctTotal.textContent = "—";
        el.totalAdd.textContent = "—";
        el.estado.textContent = "Completa datos";
        [el.copyBtn, el.txtBtn, el.csvBtn, el.printBtn].forEach((btn) => { btn.disabled = true; });

        if (hasError) setError("Completa volumen y densidad. Revisa campos en rojo.");
        lastComputed = { canCompute: false };
        saveState();
        return;
      }

      const masaTotalKg = volL * densKgL;
      const masaSolidosKg = masaTotalKg * solFrac;
      el.outMasaTotal.textContent = formatKg(masaTotalKg);
      el.outMasaSolidos.textContent = formatKg(masaSolidosKg);

      let totalPct = 0;
      let totalG = 0;

      state.colorants.forEach((colorant, idx) => {
        const pct = parseNumber(colorant.pct);
        const pctClamped = Number.isFinite(pct) ? pct : 0;
        totalPct += pctClamped;

        const grams = masaSolidosKg * (pctClamped / 100) * 1000;
        totalG += grams;

        const pretty = massToPretty(grams);
        const main = document.getElementById(`colorResultMain-${idx}`);
        const sub = document.getElementById(`colorResultSub-${idx}`);
        if (main) main.textContent = pretty.main;
        if (sub) sub.textContent = pretty.sub || "";
      });

      el.pctTotal.textContent = formatPct(totalPct);
      el.totalAdd.textContent = massToPretty(totalG).main;

      if (totalPct > 100.0001) {
        el.estado.textContent = "Revisar % total";
        setError("El porcentaje total excede 100%. Ajusta los valores.");
      } else if (totalPct === 0) {
        el.estado.textContent = "Sin porcentaje";
      } else {
        el.estado.textContent = "OK";
      }

      const hasAny = state.colorants.some((c) => {
        const p = parseNumber(c.pct);
        return (Number.isFinite(p) && p > 0) || String(c.name || "").trim().length > 0;
      });
      [el.copyBtn, el.txtBtn, el.csvBtn, el.printBtn].forEach((btn) => { btn.disabled = !hasAny; });

      lastComputed = {
        canCompute: true,
        totalG,
        tipo,
        volL,
        densKgL,
        solFrac,
        masaTotalKg,
        masaSolidosKg,
        totalPct,
        colorants: state.colorants.map((c, idx) => {
          const pct = parseNumber(c.pct);
          const pctClamped = Number.isFinite(pct) ? pct : 0;
          const grams = masaSolidosKg * (pctClamped / 100) * 1000;
          return {
            num: idx + 1,
            name: String(c.name || "").trim() || `Colorante ${idx + 1}`,
            pct: pctClamped,
            grams
          };
        }).filter((item) => item.pct > 0 || !/^Colorante \d+$/.test(item.name))
      };

      saveState();
    }

    function generateTextReport() {
      if (!lastComputed || !lastComputed.canCompute) {
        return "No hay datos para generar el reporte.";
      }

      const fecha = new Date().toLocaleDateString("es-CO", {
        year: "numeric",
        month: "long",
        day: "numeric"
      });

      let report = "";
      report += "═══════════════════════════════════════════════════════════\n";
      report += "        REPORTE DE COLORANTES PARA ESMALTE\n";
      report += "═══════════════════════════════════════════════════════════\n\n";
      report += `Fecha: ${fecha}\n`;
      report += `Tipo de esmalte: ${esmaltes[lastComputed.tipo].label}\n\n`;
      report += "DATOS DEL ESMALTE\n";
      report += "-----------------------------------------------------------\n";
      report += `Volumen: ${nf4.format(lastComputed.volL)} L\n`;
      report += `Densidad: ${nf4.format(lastComputed.densKgL)} kg/L\n`;
      report += `Sólidos: ${nf2.format(lastComputed.solFrac * 100)}%\n`;
      report += `Masa total: ${nf2.format(lastComputed.masaTotalKg)} kg\n`;
      report += `Masa de sólidos: ${nf2.format(lastComputed.masaSolidosKg)} kg\n\n`;
      report += "COLORANTES A ADICIONAR\n";
      report += "-----------------------------------------------------------\n";

      if (!lastComputed.colorants.length) {
        report += "No hay colorantes diligenciados.\n";
      } else {
        lastComputed.colorants.forEach((item, idx) => {
          report += `${idx + 1}. ${item.name}\n`;
          report += `   Porcentaje: ${nf2.format(item.pct)}%\n`;
          report += `   Cantidad: ${nf3.format(item.grams)} g`;
          if (item.grams >= 1000) report += ` (${nf3.format(item.grams / 1000)} kg)`;
          report += "\n\n";
        });
      }

      report += "RESUMEN\n";
      report += "-----------------------------------------------------------\n";
      report += `Porcentaje total: ${nf2.format(lastComputed.totalPct)}%\n`;
      report += `Total a adicionar: ${nf3.format(lastComputed.totalG)} g`;
      if (lastComputed.totalG >= 1000) report += ` (${nf3.format(lastComputed.totalG / 1000)} kg)`;
      report += "\n";
      return report;
    }

    function generateCSV() {
      if (!lastComputed || !lastComputed.canCompute) return "No hay datos para exportar.";

      let csv = "REPORTE DE COLORANTES PARA ESMALTE\n";
      csv += `Fecha,${new Date().toLocaleDateString("es-CO")}\n`;
      csv += `Tipo,${esmaltes[lastComputed.tipo].label}\n\n`;
      csv += "DATOS DEL ESMALTE\n";
      csv += "Parámetro,Valor,Unidad\n";
      csv += `Volumen,${nf4.format(lastComputed.volL)},L\n`;
      csv += `Densidad,${nf4.format(lastComputed.densKgL)},kg/L\n`;
      csv += `Sólidos,${nf2.format(lastComputed.solFrac * 100)},%\n`;
      csv += `Masa total,${nf2.format(lastComputed.masaTotalKg)},kg\n`;
      csv += `Masa de sólidos,${nf2.format(lastComputed.masaSolidosKg)},kg\n\n`;
      csv += "COLORANTES\n";
      csv += "Número,Nombre,Porcentaje (%),Cantidad (g),Cantidad (kg)\n";

      lastComputed.colorants.forEach((item) => {
        csv += `${item.num},"${item.name}",${nf2.format(item.pct)},${nf3.format(item.grams)},${item.grams >= 1000 ? nf3.format(item.grams / 1000) : ""}\n`;
      });

      csv += "\nRESUMEN\n";
      csv += `Porcentaje total,${nf2.format(lastComputed.totalPct)},%\n`;
      csv += `Total a adicionar,${nf3.format(lastComputed.totalG)},g\n`;
      return csv;
    }

    async function handleCopy() {
      const ok = await copyText(generateTextReport());
      showToast(ok ? "Reporte copiado." : "No se pudo copiar el reporte.");
    }

    function handleTxt() {
      downloadFile(`reporte-colorantes-${new Date().toISOString().slice(0, 10)}.txt`, "text/plain;charset=utf-8", generateTextReport());
      showToast("TXT descargado.");
    }

    function handleCsv() {
      downloadFile(`reporte-colorantes-${new Date().toISOString().slice(0, 10)}.csv`, "text/csv;charset=utf-8", "\ufeff" + generateCSV());
      showToast("CSV descargado.");
    }

    function bindEvents() {
      el.tipo.addEventListener("change", () => {
        state.tipo = el.tipo.value;
        saveState();
        compute();
      });
      el.volumen.addEventListener("input", () => {
        state.vol = el.volumen.value;
        saveState();
        compute();
      });
      el.volumenUnidad.addEventListener("change", () => {
        state.volU = el.volumenUnidad.value;
        saveState();
        compute();
      });
      el.densidad.addEventListener("input", () => {
        state.dens = el.densidad.value;
        saveState();
        compute();
      });
      el.densidadUnidad.addEventListener("change", () => {
        state.densU = el.densidadUnidad.value;
        updateDensityPlaceholder();
        saveState();
        compute();
      });

      el.addBtn.addEventListener("click", () => {
        if (state.colorants.length >= MAX_COLORANTS) {
          showToast(`Máximo ${MAX_COLORANTS} colorantes.`);
          return;
        }
        state.colorants.push({ name: "", pct: "" });
        saveState();
        renderColorants();
        compute();
        showToast("Colorante añadido.");
      });

      el.clearBtn.addEventListener("click", () => {
        state.colorants = defaultColorants();
        saveState();
        renderColorants();
        compute();
        showToast("Campos reiniciados.");
      });

      el.copyBtn.addEventListener("click", handleCopy);
      el.txtBtn.addEventListener("click", handleTxt);
      el.csvBtn.addEventListener("click", handleCsv);
      el.printBtn.addEventListener("click", () => window.print());
    }

    function init() {
      queryEls();
      state = loadState();
      renderInputs();
      renderColorants();
      bindEvents();
      if (el.detailsSolidos) el.detailsSolidos.open = false;
      compute();
    }

    return { init };
  })();

  const TankModule = (() => {
    const MAX_HIST = 25;
    const EXTRAP_TOL_CM = 2;
    const TABLE_PREVIEW_ROWS = 40;

    const DATA = DATASETS.tanks;

    const cache = new Map();
    const tableExpandedByKey = new Map();
    let el;

    function queryEls() {
      el = {
        select: document.getElementById("tankSelect"),
        mode: document.getElementById("tankMode"),
        value: document.getElementById("tankValue"),
        valueLabel: document.getElementById("tankValueLabel"),
        range: document.getElementById("tankRange"),
        meta: document.getElementById("tankMeta"),
        modeHelp: document.getElementById("tankModeHelp"),
        allowExtrap: document.getElementById("tankAllowExtrap"),
        extrapToggle: document.getElementById("tankExtrapToggle"),
        extrapHelp: document.getElementById("tankExtrapHelp"),
        saveBtn: document.getElementById("tankSaveBtn"),
        clearBtn: document.getElementById("tankClearBtn"),
        resetBtn: document.getElementById("tankResetStateBtn"),
        error: document.getElementById("tankError"),
        warning: document.getElementById("tankWarning"),
        result: document.getElementById("tankResult"),
        resultTitle: document.getElementById("tankResultTitle"),
        resultSub: document.getElementById("tankResultSub"),
        outAltura: document.getElementById("tankOutAltura"),
        outAlturaSub: document.getElementById("tankOutAlturaSub"),
        outLitros: document.getElementById("tankOutLitros"),
        outLitrosSub: document.getElementById("tankOutLitrosSub"),
        outVacio: document.getElementById("tankOutVacio"),
        outVacioSub: document.getElementById("tankOutVacioSub"),
        outPct: document.getElementById("tankOutPct"),
        outPctSub: document.getElementById("tankOutPctSub"),
        toast: document.getElementById("tankToast"),
        tableData: document.getElementById("tankTableData"),
        history: document.getElementById("tankHistory"),
        histCopyBtn: document.getElementById("tankHistCopyBtn"),
        histCsvBtn: document.getElementById("tankHistCsvBtn"),
        histClearBtn: document.getElementById("tankHistClearBtn")
      };
    }

    function getTank(key) {
      if (cache.has(key)) return cache.get(key);

      const def = DATA[key];
      const type = Array.isArray(def) ? "table" : (def?.type || "table");
      let rawPoints;
      let meta = { type };

      if (type === "linear") {
        const maxH = Number(def.maxH);
        const litersPerCm = Number(def.litersPerCm);
        const maxL = maxH * litersPerCm;
        rawPoints = [[0, 0], [maxH, maxL]];
        meta = { type: "linear", maxH, litersPerCm, maxL };
      } else {
        rawPoints = Array.isArray(def) ? def : def.points;
        meta = { type: "table" };
      }

      const points = rawPoints.map(([h, l]) => ({ h: Number(h), l: Number(l) })).sort((a, b) => a.h - b.h);
      const tank = {
        key,
        points,
        minH: points[0].h,
        maxH: points[points.length - 1].h,
        minL: points[0].l,
        maxL: points[points.length - 1].l,
        count: points.length,
        meta
      };
      cache.set(key, tank);
      return tank;
    }

    function isLinear(tank) {
      return tank.meta?.type === "linear";
    }

    function showError(msg) {
      el.error.textContent = msg;
      el.error.hidden = false;
    }

    function clearError() {
      el.error.hidden = true;
      el.error.textContent = "";
    }

    function showWarning(msg) {
      el.warning.textContent = msg;
      el.warning.hidden = false;
    }

    function clearWarning() {
      el.warning.hidden = true;
      el.warning.textContent = "";
    }

    function setToast(msg) {
      el.toast.textContent = msg || "";
    }

    function getHeightRange(tank, allowExtrap) {
      const min = allowExtrap ? Math.max(0, tank.minH - EXTRAP_TOL_CM) : tank.minH;
      const max = allowExtrap ? tank.maxH + EXTRAP_TOL_CM : tank.maxH;
      return { min, max };
    }

    function getLitersTolFrom2cm(tank) {
      if (isLinear(tank)) {
        const tol = Math.abs(tank.meta.litersPerCm) * EXTRAP_TOL_CM;
        return { low: tol, high: tol };
      }

      const pts = tank.points;
      if (pts.length < 2) return { low: 0, high: 0 };

      const p0 = pts[0];
      const p1 = pts[1];
      const p2 = pts[pts.length - 2];
      const p3 = pts[pts.length - 1];

      const slopeLow = (p1.h - p0.h) !== 0 ? (p1.l - p0.l) / (p1.h - p0.h) : 0;
      const slopeHigh = (p3.h - p2.h) !== 0 ? (p3.l - p2.l) / (p3.h - p2.h) : 0;

      return {
        low: Math.abs(slopeLow) * EXTRAP_TOL_CM,
        high: Math.abs(slopeHigh) * EXTRAP_TOL_CM
      };
    }

    function getLitersRange(tank, allowExtrap) {
      if (!allowExtrap) return { min: tank.minL, max: tank.maxL };
      const tol = getLitersTolFrom2cm(tank);
      return { min: Math.max(0, tank.minL - tol.low), max: tank.maxL + tol.high };
    }

    function getEmptyRange(tank, allowExtrap) {
      const minEmpty = allowExtrap ? -EXTRAP_TOL_CM : 0;
      const baseMinH = isLinear(tank) ? 0 : tank.minH;
      const heightRange = getHeightRange(tank, allowExtrap);
      const maxEmpty = tank.maxH - Math.max(baseMinH, heightRange.min);
      return { minEmpty, maxEmpty, baseMinH };
    }

    function interpWithExtrap(points, x, xKey, yKey, allowExtrap, tol) {
      const n = points.length;
      const minX = points[0][xKey];
      const maxX = points[n - 1][xKey];
      const tolLow = typeof tol === "number" ? tol : (tol?.low ?? 0);
      const tolHigh = typeof tol === "number" ? tol : (tol?.high ?? 0);

      if (x < minX) {
        if (!allowExtrap || x < minX - tolLow) return null;
        const a = points[0];
        const b = points[1];
        const denom = b[xKey] - a[xKey];
        if (denom === 0) return null;
        return { value: a[yKey] + (x - a[xKey]) * (b[yKey] - a[yKey]) / denom, extrapolated: true };
      }

      if (x > maxX) {
        if (!allowExtrap || x > maxX + tolHigh) return null;
        const a = points[n - 2];
        const b = points[n - 1];
        const denom = b[xKey] - a[xKey];
        if (denom === 0) return null;
        return { value: a[yKey] + (x - a[xKey]) * (b[yKey] - a[yKey]) / denom, extrapolated: true };
      }

      for (let i = 0; i < n - 1; i += 1) {
        const x0 = points[i][xKey];
        const x1 = points[i + 1][xKey];
        if (x >= x0 && x <= x1) {
          const y0 = points[i][yKey];
          const y1 = points[i + 1][yKey];
          const t = (x - x0) / (x1 - x0);
          return { value: y0 + t * (y1 - y0), extrapolated: false };
        }
      }
      return null;
    }

    function validateInput(tank, mode, value, allowExtrap) {
      if (!Number.isFinite(value)) return "Ingresa un número válido (coma o punto).";

      if (mode === "altura") {
        if (value < 0) return "La altura no puede ser negativa.";
        const range = getHeightRange(tank, allowExtrap);
        if (value < range.min || value > range.max) {
          return allowExtrap
            ? `Altura fuera del rango permitido. Calibrado: ${nf2.format(tank.minH)}–${nf2.format(tank.maxH)} cm. Con extrapolación: ${nf2.format(range.min)}–${nf2.format(range.max)} cm.`
            : `Altura fuera de rango. Rango: ${nf2.format(tank.minH)}–${nf2.format(tank.maxH)} cm.`;
        }
        return null;
      }

      if (mode === "litros") {
        if (value < 0) return "Los litros no pueden ser negativos.";
        const range = getLitersRange(tank, allowExtrap);
        if (value < range.min || value > range.max) {
          return allowExtrap
            ? `Litros fuera del rango permitido. Calibrado: ${nf2.format(tank.minL)}–${nf2.format(tank.maxL)} L. Con extrapolación: ${nf2.format(range.min)}–${nf2.format(range.max)} L.`
            : `Litros fuera de rango. Rango: ${nf2.format(tank.minL)}–${nf2.format(tank.maxL)} L.`;
        }
        return null;
      }

      const emptyRange = getEmptyRange(tank, allowExtrap);
      const calMax = tank.maxH - emptyRange.baseMinH;
      if (value < emptyRange.minEmpty || value > emptyRange.maxEmpty) {
        return allowExtrap
          ? `Vacío fuera del rango permitido. Calibrado: 0–${nf2.format(calMax)} cm. Con extrapolación: ${nf2.format(emptyRange.minEmpty)}–${nf2.format(emptyRange.maxEmpty)} cm.`
          : `Vacío fuera de rango. Rango: 0–${nf2.format(calMax)} cm.`;
      }
      return null;
    }

    function computeResult(tank, mode, value, allowExtrap) {
      let h = null;
      let l = null;
      let extrapolated = false;

      if (mode === "altura") {
        h = value;
        const result = interpWithExtrap(tank.points, h, "h", "l", allowExtrap, EXTRAP_TOL_CM);
        if (!result) return null;
        l = result.value;
        extrapolated = result.extrapolated;
      } else if (mode === "litros") {
        l = value;
        const tolL = getLitersTolFrom2cm(tank);
        const result = interpWithExtrap(tank.points, l, "l", "h", allowExtrap, { low: tolL.low, high: tolL.high });
        if (!result) return null;
        h = result.value;
        extrapolated = result.extrapolated;
      } else {
        const emptyInput = value;
        h = tank.maxH - emptyInput;
        const result = interpWithExtrap(tank.points, h, "h", "l", allowExtrap, EXTRAP_TOL_CM);
        if (!result) return null;
        l = result.value;
        extrapolated = result.extrapolated;
      }

      if (Number.isFinite(l) && l < 0) {
        l = 0;
        extrapolated = true;
      }
      const empty = tank.maxH - h;
      let pct = tank.maxL > 0 ? (l / tank.maxL) * 100 : NaN;
      if (Number.isFinite(pct)) pct = Math.max(0, Math.min(100, pct));
      return { h, l, empty, pct, extrapolated };
    }

    function updateTankMeta() {
      const tank = getTank(el.select.value);
      if (isLinear(tank)) {
        el.meta.textContent = `Altura máxima: ${nf2.format(tank.meta.maxH)} cm • 1 cm = ${nf2.format(tank.meta.litersPerCm)} L • Capacidad: ${nf2.format(tank.meta.maxL)} L`;
      } else {
        el.meta.textContent = `Altura calibrada: ${nf2.format(tank.minH)}–${nf2.format(tank.maxH)} cm • Capacidad: ${nf2.format(tank.maxL)} L • Filas: ${tank.count}`;
      }
    }

    function updateExtrapUI() {
      const tank = getTank(el.select.value);
      if (isLinear(tank)) {
        el.allowExtrap.checked = false;
        el.allowExtrap.disabled = true;
        el.extrapToggle.setAttribute("aria-disabled", "true");
        el.extrapHelp.textContent = "En silos lineales se usa el rango físico 0–altura máxima.";
      } else {
        el.allowExtrap.disabled = false;
        el.extrapToggle.removeAttribute("aria-disabled");
        el.extrapHelp.textContent = "Útil si la medición quedó cerca del rango calibrado.";
      }
    }

    function updateModeUI() {
      const mode = el.mode.value;
      const tank = getTank(el.select.value);
      const allowExtrap = el.allowExtrap.checked;

      el.value.classList.remove("invalid");
      clearError();
      clearWarning();
      setToast("");

      if (mode === "altura") {
        const range = getHeightRange(tank, allowExtrap);
        el.valueLabel.textContent = "Altura (cm)";
        el.value.placeholder = "Ej: 39";
        el.modeHelp.textContent = "Ingresa altura y obtén litros, vacío y porcentaje.";
        el.range.textContent = allowExtrap
          ? `Calibrado: ${nf2.format(tank.minH)}–${nf2.format(tank.maxH)} cm • Extrapolación: ${nf2.format(range.min)}–${nf2.format(range.max)} cm.`
          : `Calibrado: ${nf2.format(tank.minH)}–${nf2.format(tank.maxH)} cm.`;
        return;
      }

      if (mode === "litros") {
        const range = getLitersRange(tank, allowExtrap);
        el.valueLabel.textContent = "Litros (L)";
        el.value.placeholder = "Ej: 400";
        el.modeHelp.textContent = "Ingresa litros y obtén altura, vacío y porcentaje.";
        el.range.textContent = allowExtrap
          ? `Calibrado: ${nf2.format(tank.minL)}–${nf2.format(tank.maxL)} L • Extrapolación: ${nf2.format(range.min)}–${nf2.format(range.max)} L.`
          : `Calibrado: ${nf2.format(tank.minL)}–${nf2.format(tank.maxL)} L.`;
        return;
      }

      const emptyRange = getEmptyRange(tank, allowExtrap);
      const calMax = tank.maxH - emptyRange.baseMinH;
      el.valueLabel.textContent = "Vacío (cm)";
      el.value.placeholder = "Ej: 100";
      el.modeHelp.textContent = "Ingresa vacío y obtén litros, altura y porcentaje.";
      el.range.textContent = allowExtrap
        ? `Calibrado: 0–${nf2.format(calMax)} cm • Extrapolación: ${nf2.format(emptyRange.minEmpty)}–${nf2.format(emptyRange.maxEmpty)} cm.`
        : `Calibrado: 0–${nf2.format(calMax)} cm.`;
    }

    function hideResult() {
      el.result.classList.remove("active");
      el.resultSub.textContent = "—";
      el.outAltura.textContent = "—";
      el.outAlturaSub.textContent = "—";
      el.outLitros.textContent = "—";
      el.outLitrosSub.textContent = "—";
      el.outVacio.textContent = "—";
      el.outVacioSub.textContent = "—";
      el.outPct.textContent = "—";
      el.outPctSub.textContent = "—";
      setToast("");
    }

    function showResult(result, mode, inputValue, saved) {
      const tank = getTank(el.select.value);
      el.result.classList.add("active");
      el.resultTitle.textContent = `Resultado • ${tank.key}`;
      el.resultSub.textContent = `Modo: ${modeText(mode)} • Entrada: ${nf2.format(inputValue)} • Interpolación lineal.${result.extrapolated ? ` Estimado por extrapolación (±${EXTRAP_TOL_CM} cm).` : ""} ${saved ? "Guardado en historial." : "Vista previa."}`;
      el.outAltura.textContent = `${nf2.format(result.h)} cm`;
      el.outLitros.textContent = `${nf2.format(result.l)} L`;
      el.outVacio.textContent = `${nf2.format(result.empty)} cm`;
      el.outPct.textContent = `${nf2.format(result.pct)}%`;

      el.outAlturaSub.textContent = result.extrapolated ? "estimado" : "calibrado";
      if (isLinear(tank)) {
        el.outLitrosSub.textContent = `k = ${nf2.format(tank.meta.litersPerCm)} L/cm`;
        el.outVacioSub.textContent = `máx = ${nf2.format(tank.meta.maxH)} cm`;
        el.outPctSub.textContent = `cap = ${nf2.format(tank.meta.maxL)} L`;
      } else {
        el.outLitrosSub.textContent = `tabla (${tank.count} filas)`;
        el.outVacioSub.textContent = `h máx = ${nf2.format(tank.maxH)} cm`;
        el.outPctSub.textContent = `cap = ${nf2.format(tank.maxL)} L`;
      }
      setToast(saved ? "Guardado." : "");
    }

    function renderTable() {
      const tank = getTank(el.select.value);
      if (isLinear(tank)) {
        el.tableData.innerHTML = `
          <div class="alert">
            <strong>Modelo lineal</strong><br />
            <span class="muted">Litros = altura(cm) × ${nf2.format(tank.meta.litersPerCm)}</span><br />
            <span class="muted">Altura máx: ${nf2.format(tank.meta.maxH)} cm • Capacidad: ${nf2.format(tank.meta.maxL)} L</span>
          </div>
        `;
        return;
      }

      const expanded = !!tableExpandedByKey.get(tank.key);
      const total = tank.points.length;
      const showCount = expanded ? total : Math.min(TABLE_PREVIEW_ROWS, total);

      let html = `
        <div class="alert">
          <strong>Tabla</strong><br />
          <span class="muted">Altura (cm) ↔ Litros (L)</span>
        </div>
      `;

      if (total > TABLE_PREVIEW_ROWS) {
        html += `
          <div class="btns" style="margin-top:10px;">
            <button class="btn btn-secondary" id="tankToggleTableBtn" type="button">${expanded ? "Ver menos" : `Ver todo (${total} filas)`}</button>
          </div>
        `;
      }

      html += `
        <div style="margin-top:12px; overflow:auto; border:1px solid var(--border); border-radius:16px; background:#fff; max-height:420px;">
          <table style="width:100%; border-collapse:collapse; min-width:520px">
            <thead>
              <tr style="background:var(--primary); color:#fff">
                <th style="padding:12px">Altura</th>
                <th style="padding:12px">Litros</th>
              </tr>
            </thead>
            <tbody>
      `;

      for (let i = 0; i < showCount; i += 1) {
        const point = tank.points[i];
        html += `
          <tr>
            <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(point.h)}</td>
            <td style="padding:10px; text-align:center; border-bottom:1px solid #eef2f7">${nf2.format(point.l)}</td>
          </tr>
        `;
      }

      if (!expanded && total > showCount) {
        html += `<tr><td colspan="2" style="padding:10px; text-align:center; color:var(--muted)">… (${total - showCount} filas ocultas)</td></tr>`;
      }

      html += "</tbody></table></div>";
      el.tableData.innerHTML = html;

      const toggleBtn = document.getElementById("tankToggleTableBtn");
      if (toggleBtn) {
        toggleBtn.addEventListener("click", () => {
          tableExpandedByKey.set(tank.key, !expanded);
          renderTable();
        }, { once: true });
      }
    }

    function loadHistory() {
      const raw = Storage.get(KEYS.tankHist, []);
      return Array.isArray(raw) ? raw : [];
    }

    function saveHistory(hist) {
      Storage.set(KEYS.tankHist, hist.slice(0, MAX_HIST));
    }

    function addHistoryEntry(entry) {
      const hist = loadHistory();
      hist.unshift(entry);
      saveHistory(hist);
      updateHomeSummary();
    }

    function renderHistory() {
      const hist = loadHistory();
      if (!hist.length) {
        el.history.innerHTML = "<div class='alert'><strong>Sin registros</strong></div>";
        return;
      }
      let html = "<div style='display:grid; gap:12px; margin-top:6px'>";
      hist.forEach((r) => {
        html += `
          <div style="border:1px solid var(--border); border-radius:16px; padding:14px; background:#fff">
            <div style="display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap">
              <div><div style="color:var(--muted); font-size:.82rem">Fecha</div><div style="font-weight:950">${r.fecha}</div></div>
              <div><div style="color:var(--muted); font-size:.82rem">Tanque / silo</div><div style="font-weight:950">${r.tanque}</div></div>
            </div>
            <div style="margin-top:8px; color:var(--muted)"><strong>${r.modo}</strong> • ${r.tipo === "lineal" ? `lineal k=${r.k}` : "tabla"} • Entrada: <strong>${r.entrada}</strong></div>
            <div style="margin-top:8px; display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap; color:var(--muted)">
              <span>Altura: <strong>${r.altura} cm</strong></span>
              <span>Litros: <strong>${r.litros} L</strong></span>
              <span>Vacío: <strong>${r.vacio} cm</strong></span>
              <span>%: <strong>${r.pct}</strong></span>
            </div>
          </div>
        `;
      });
      html += "</div>";
      el.history.innerHTML = html;
    }

    async function copyHistory() {
      const hist = loadHistory();
      if (!hist.length) {
        setToast("No hay historial para copiar.");
        return;
      }
      let text = "=== HISTORIAL TANQUES ===\n\n";
      hist.forEach((r) => {
        const meta = r.tipo === "lineal" ? ` | lineal | k=${r.k}` : " | tabla";
        text += `${r.fecha} | ${r.tanque} | ${r.modo}${meta} | entrada: ${r.entrada} | altura: ${r.altura} cm | litros: ${r.litros} L | vacío: ${r.vacio} cm | %: ${r.pct}\n`;
      });

      const ok = await copyText(text);
      setToast(ok ? "Historial copiado." : "No se pudo copiar el historial.");
    }

    function exportHistoryCSV() {
      const hist = loadHistory();
      if (!hist.length) {
        setToast("No hay historial para exportar.");
        return;
      }
      const lines = ["fecha,tanque,tipo,k,modo,entrada,altura_cm,litros,vacio_cm,porcentaje"];
      hist.forEach((r) => {
        lines.push(`"${r.fecha}","${r.tanque}","${r.tipo}","${r.k || ""}","${r.modo}","${r.entrada}","${r.altura}","${r.litros}","${r.vacio}","${r.pct}"`);
      });
      downloadFile(`historial_tanques_${new Date().toISOString().slice(0, 10)}.csv`, "text/csv;charset=utf-8", lines.join("\n"));
      setToast("CSV descargado.");
    }

    function loadState() {
      const state = Storage.get(KEYS.tankState, null);
      return state && typeof state === "object" ? state : {};
    }

    function saveState() {
      Storage.set(KEYS.tankState, {
        tank: el.select.value,
        mode: el.mode.value,
        value: el.value.value,
        allowExtrap: el.allowExtrap.checked
      });
    }

    function resetState() {
      Storage.remove(KEYS.tankState);
      el.value.value = "";
      el.allowExtrap.checked = false;
      hideResult();
      clearError();
      clearWarning();
      updateExtrapUI();
      renderTable();
      updateModeUI();
      saveState();
      setToast("Estado restablecido.");
    }

    function clearInputs() {
      el.value.value = "";
      el.value.classList.remove("invalid");
      clearError();
      clearWarning();
      hideResult();
      saveState();
    }

    function runCalc(saveToHistory) {
      clearError();
      clearWarning();
      el.value.classList.remove("invalid");

      if (!el.value.value.trim()) {
        hideResult();
        saveState();
        return;
      }

      const tank = getTank(el.select.value);
      const mode = el.mode.value;
      const allowExtrap = el.allowExtrap.checked;
      const value = parseNumber(el.value.value);
      const error = validateInput(tank, mode, value, allowExtrap);

      if (error) {
        showError(error);
        el.value.classList.add("invalid");
        hideResult();
        saveState();
        return;
      }

      const result = computeResult(tank, mode, value, allowExtrap);
      if (!result) {
        showError("No se pudo calcular con el rango actual.");
        el.value.classList.add("invalid");
        hideResult();
        saveState();
        return;
      }

      if (result.extrapolated) showWarning(`Resultado estimado por extrapolación (±${EXTRAP_TOL_CM} cm).`);
      else clearWarning();

      showResult(result, mode, value, saveToHistory);

      if (saveToHistory) {
        addHistoryEntry({
          fecha: nowStamp(),
          tanque: tank.key,
          tipo: isLinear(tank) ? "lineal" : "tabla",
          k: isLinear(tank) ? nf2.format(tank.meta.litersPerCm) : "",
          modo: `${modeText(mode)}${result.extrapolated ? " (estimado)" : ""}`,
          entrada: `${nf2.format(value)} ${mode === "litros" ? "L" : "cm"}`,
          altura: nf2.format(result.h),
          litros: nf2.format(result.l),
          vacio: nf2.format(result.empty),
          pct: `${nf2.format(result.pct)}%`
        });
        renderHistory();
      }

      saveState();
    }

    function populateSelect() {
      const keys = Object.keys(DATA);
      const tableKeys = keys.filter((key) => (Array.isArray(DATA[key]) || DATA[key]?.type === "table"));
      const linearKeys = keys.filter((key) => DATA[key]?.type === "linear");

      tableKeys.sort((a, b) => {
        const na = Number.parseInt(a, 10);
        const nb = Number.parseInt(b, 10);
        const fa = Number.isFinite(na);
        const fb = Number.isFinite(nb);
        if (fa && fb) return na - nb;
        if (fa) return -1;
        if (fb) return 1;
        return a.localeCompare(b, "es");
      });
      linearKeys.sort((a, b) => a.localeCompare(b, "es"));

      el.select.innerHTML = `
        <optgroup label="Tanques (tabla)">
          ${tableKeys.map((key) => `<option value="${key}">${key}</option>`).join("")}
        </optgroup>
        <optgroup label="Silos">
          ${linearKeys.map((key) => `<option value="${key}">${key}</option>`).join("")}
        </optgroup>
      `;
    }

    function restoreState() {
      const state = loadState();
      if (state.tank && DATA[state.tank]) el.select.value = state.tank;
      if (state.mode) el.mode.value = state.mode;
      if (typeof state.value === "string") el.value.value = state.value;
      if (typeof state.allowExtrap === "boolean") el.allowExtrap.checked = state.allowExtrap;
    }

    function bindEvents() {
      el.select.addEventListener("change", () => {
        updateTankMeta();
        updateExtrapUI();
        updateModeUI();
        renderTable();
        hideResult();
        saveState();
        if (el.value.value.trim()) runCalc(false);
      });

      el.mode.addEventListener("change", () => {
        updateModeUI();
        hideResult();
        saveState();
        if (el.value.value.trim()) runCalc(false);
      });

      el.allowExtrap.addEventListener("change", () => {
        updateModeUI();
        saveState();
        if (el.value.value.trim()) runCalc(false);
      });

      el.value.addEventListener("input", () => {
        saveState();
        if (el.value.value.trim()) runCalc(false);
        else {
          clearError();
          clearWarning();
          hideResult();
        }
      });

      el.value.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          runCalc(true);
        }
      });

      el.saveBtn.addEventListener("click", () => runCalc(true));
      el.clearBtn.addEventListener("click", clearInputs);
      el.resetBtn.addEventListener("click", () => {
        if (!askConfirm("¿Seguro que quieres restablecer el estado guardado de tanques?")) return;
        resetState();
      });
      el.histCopyBtn.addEventListener("click", copyHistory);
      el.histCsvBtn.addEventListener("click", exportHistoryCSV);
      el.histClearBtn.addEventListener("click", () => {
        if (!askConfirm("¿Seguro que quieres borrar el historial de tanques en este dispositivo?")) return;
        Storage.remove(KEYS.tankHist);
        renderHistory();
        updateHomeSummary();
        setToast("Historial eliminado.");
      });
    }

    function init() {
      queryEls();
      populateSelect();
      restoreState();
      updateTankMeta();
      updateExtrapUI();
      updateModeUI();
      renderTable();
      renderHistory();
      bindEvents();

      if (window.matchMedia("(max-width: 820px)").matches) {
        document.getElementById("tankDetailsTable").open = false;
        document.getElementById("tankDetailsHistory").open = false;
      }

      if (el.value.value.trim()) runCalc(false);
    }

    return { init };
  })();


  function initNetworkStatus() {
    const el = document.getElementById("networkStatus");
    if (!el) return;

    function paint() {
      const online = navigator.onLine;
      el.textContent = online ? "En línea" : "Sin conexión";
      el.classList.toggle("online", online);
      el.classList.toggle("offline", !online);
    }

    paint();
    window.addEventListener("online", paint);
    window.addEventListener("offline", paint);
  }

  function exportBackup() {
    const payload = {
      exportedAt: new Date().toISOString(),
      version: 2,
      data: {
        [KEYS.plantMode]: Storage.get(KEYS.plantMode, false),
        [KEYS.silosState]: Storage.get(KEYS.silosState, null),
        [KEYS.silosHist]: Storage.get(KEYS.silosHist, []),
        [KEYS.colorState]: Storage.get(KEYS.colorState, null),
        [KEYS.tankState]: Storage.get(KEYS.tankState, null),
        [KEYS.tankHist]: Storage.get(KEYS.tankHist, [])
      }
    };
    downloadFile(`planta_suite_respaldo_${new Date().toISOString().slice(0, 10)}.json`, "application/json;charset=utf-8", JSON.stringify(payload, null, 2));
    const status = document.getElementById("backupStatus");
    if (status) status.textContent = "Respaldo exportado.";
  }

  function wipeAllLocalData() {
    if (!askConfirm("Esto borrará estados e historiales guardados en este navegador. ¿Deseas continuar?")) return;
    Object.values(KEYS).forEach((key) => Storage.remove(key));
    const status = document.getElementById("backupStatus");
    if (status) status.textContent = "Datos locales borrados. Recarga la app para empezar limpio.";
    updateHomeSummary();
  }

  function initBackupTools() {
    const exportBtn = document.getElementById("backupExportBtn");
    const importInput = document.getElementById("backupImportInput");
    const wipeBtn = document.getElementById("backupWipeBtn");
    const status = document.getElementById("backupStatus");

    if (exportBtn) exportBtn.addEventListener("click", exportBackup);
    if (wipeBtn) wipeBtn.addEventListener("click", wipeAllLocalData);

    if (importInput) {
      importInput.addEventListener("change", async () => {
        const file = importInput.files?.[0];
        if (!file) return;
        try {
          const text = await file.text();
          const parsed = JSON.parse(text);
          if (!parsed || typeof parsed !== "object" || !parsed.data) throw new Error("Formato inválido");
          Object.entries(parsed.data).forEach(([key, value]) => {
            Storage.set(key, value);
          });
          if (status) status.textContent = "Respaldo importado. Recarga la app para reflejar todos los cambios.";
          updateHomeSummary();
        } catch {
          if (status) status.textContent = "No se pudo importar el archivo JSON.";
        } finally {
          importInput.value = "";
        }
      });
    }
  }

  function initServiceWorker() {
    if (!("serviceWorker" in navigator)) return;
    window.addEventListener("load", () => {
      navigator.serviceWorker.register("./service-worker.js").catch(() => {
        // ignore service worker errors
      });
    });
  }

  document.addEventListener("DOMContentLoaded", async () => {
    await loadDatasets();
    setCurrentYear();
    initPlantMode();
    initInstallPrompt();
    initRouting();
    initNetworkStatus();
    initBackupTools();
    SilosModule.init();
    ColorModule.init();
    TankModule.init();
    updateHomeSummary();
    initServiceWorker();
  });
})();